<%= turbo_frame_tag "like_section_#{post.id}", style: "display: contents;" do %>
    <div class="flex items-center">
        <% if post.liked_by?(current_user) %>
            <%= button_to post_post_likes_path(post),
                method: :delete,
                form: { class: "inline-flex items-center" },
                class: "inline-flex items-center gap-2 leading-none text-red-500 hover:text-red-400 transition p-0 align-middle bg-transparent border-0 shadow-none",
                data: { turbo_frame: "like_section_#{post.id}" } do %>
                <i data-feather="heart" class="w-5 h-5 fill-current"></i>
                <span class="inline-flex items-center leading-none"><%= post.likes_count %> <%= 'like'.pluralize(post.likes_count) %></span>
            <% end %>
        <% else %>
            <%= button_to post_post_likes_path(post),
                method: :post,
                form: { class: "inline-flex items-center" },
                class: "inline-flex items-center gap-2 leading-none text-gray-400 hover:text-red-500 transition p-0 align-middle bg-transparent border-0 shadow-none",
                data: { turbo_frame: "like_section_#{post.id}" } do %>
                <i data-feather="heart" class="w-5 h-5"></i>
                <span class="inline-flex items-center leading-none"><%= post.likes_count %> <%= 'like'.pluralize(post.likes_count) %></span>
            <% end %>
        <% end %>
    </div>

<% end %>

<div id="modal-post-likes-<%= post.id %>" class="fixed inset-0 z-[60] hidden justify-center items-center py-12">
    <div class="fixed inset-0 bg-black bg-opacity-75 transition-opacity backdrop-blur-sm"></div>
    <div class="relative bg-gray-800 rounded-xl shadow-2xl w-11/12 md:w-1/3 max-h-[80vh] flex flex-col border border-gray-700 transform transition-all overflow-hidden z-10">

        <div class="relative flex items-center justify-center p-4 border-b border-gray-700 bg-gray-800">
            <h3 class="text-lg font-bold text-white">Likes</h3>
            <button data-modal-hide="modal-post-likes-<%= post.id %>" class="absolute right-4 text-gray-400 hover:text-white p-1 rounded-full hover:bg-gray-700 transition">
                <i data-feather="x" class="w-5 h-5"></i>
            </button>
        </div>

        <div class="flex-1 overflow-y-auto p-4 space-y-4 thin-scrollbar">
            <% if post.post_likes.any? %>
                <% post.post_likes.each do |like| %>
                    <% 
                        liker_profile = nil
                        if like.user.club?
                            liker_profile = like.user.club_profile
                        elsif like.user.player?
                            liker_profile = like.user.player_profile
                        elsif like.user.board?
                            liker_profile = like.user.board_profile
                        elsif like.user.coach?
                            liker_profile = like.user.coach_profile
                        elsif like.user.admin?
                            liker_profile = like.user.admin_profile
                        elsif like.user.user?
                            liker_profile = like.user.user_profile
                        end
                    %>

                    <div class="flex items-center justify-between hover:bg-gray-700 p-2 rounded-lg transition">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-gray-600 overflow-hidden flex-shrink-0">
                                <% if liker_profile && liker_profile.profile_picture.attached? %>
                                    <%= image_tag url_for(liker_profile.profile_picture), class: "w-full h-full object-cover" %>
                                <% else %>
                                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                <% end %>
                            </div>

                            <div>
                                <% if like.user.club? %>
                                    <%= link_to like.user.club_profile.name, club_profile_path(like.user.club_profile), 
                                        data: { turbo_frame: "_top" }, class: "text-white font-semibold hover:underline" %>
                                <% elsif like.user.player? %>
                                    <%= link_to like.user.player_profile.name, player_profile_path(like.user.player_profile), 
                                        data: { turbo_frame: "_top" }, class: "text-white font-semibold hover:underline" %>
                                <% elsif like.user.coach? %>
                                    <%= link_to like.user.coach_profile.name, coach_profile_path(like.user.coach_profile), 
                                        data: { turbo_frame: "_top" }, class: "text-white font-semibold hover:underline" %>
                                <% elsif like.user.board? %>
                                    <%= link_to like.user.board_profile.name, board_profile_path(like.user.board_profile), 
                                        data: { turbo_frame: "_top" }, class: "text-white font-semibold hover:underline" %>
                                <% elsif like.user.user? %>
                                    <%= link_to like.user.user_profile.name, user_profile_path(like.user.user_profile), 
                                        data: { turbo_frame: "_top" }, class: "text-white font-semibold hover:underline" %>
                                <% end %>
                            </div>
                        </div>

                        <button class="px-3 py-1 bg-gray-600 hover:bg-gray-500 text-white text-sm font-medium rounded-md transition flex items-center gap-1 flex-shrink-0">
                            <i data-feather="user-check" class="w-4 h-4"></i>
                            <span>Seguir</span>
                        </button>
                    </div>
                <% end %>
            <% else %>
                <div class="text-center py-12">
                    <i data-feather="heart" class="w-16 h-16 text-gray-600 mx-auto mb-4"></i>
                    <h3 class="text-xl font-bold text-gray-400 mb-2">Este post ainda não tem nenhum like!</h3>
                </div>
            <% end %>
        </div>
    </div>
</div>
