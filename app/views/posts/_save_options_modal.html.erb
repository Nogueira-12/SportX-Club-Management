<%= turbo_frame_tag "save_section_saved_modal_#{post.id}", style: "display: contents;" do %>
    <% if post.saved_by?(current_user) %>
        <%= button_to post_post_saves_path(post),
            method: :delete,
            form: { class: "inline" },
            class: "save-post-btn block px-4 py-2 text-sm text-gray-200 hover:bg-gray-600 rounded-t-md transition-colors hover:text-red-400 clickable",
            data: { turbo_frame: "save_section_saved_modal_#{post.id}" } do %>
            <div class="flex items-center">
                <i data-feather="bookmark" class="w-4 h-4 mr-2 fill-current"></i>
                <span class="save-text">Retirar dos guardados</span>
            </div>
        <% end %>
    <% else %>
        <%= button_to post_post_saves_path(post),
            method: :post,
            form: { class: "inline" },
            class: "save-post-btn block px-4 py-2 text-sm text-gray-200 hover:bg-gray-600 rounded-t-md transition-colors hover:text-green-400 clickable",
            data: { turbo_frame: "save_section_saved_modal_#{post.id}" } do %>
            <div class="flex items-center">
                <i data-feather="bookmark" class="w-4 h-4 mr-2"></i>
                <span class="save-text">Guardar publicação</span>
            </div>
        <% end %>
    <% end %>
    <script>
        feather.replace();
    </script>
<% end %>