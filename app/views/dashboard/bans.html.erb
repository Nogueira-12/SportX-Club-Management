<body class="min-h-screen flex text-white bg-gray-900">
<!---------------------------------------------------- NOME E LOGO DO CLUBE ---------------------------------------------------->
    <div class="w-64 bg-slate-800 shadow-xl min-h-screen flex flex-col border-r border-slate-700">
    <!-- Logo e nome do clube -->
        <div class="p-6 border-b border-slate-700">
            <div class="flex items-center justify-center mb-3">
                
                <% if current_user.admin_profile.profile_picture.attached? %>
                    <%= image_tag url_for(current_user.admin_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-20 h-20 rounded-full border-1" %>
                <% end %>

                
            </div>
            <h1 class="text-lg font-bold text-center text-white">
                <%= current_user.admin_profile.name %>
            </h1>
        </div>
<!---------------------------------------------------- OPÇÕES DO SIDEBAR ---------------------------------------------------->
        <nav class="flex-1 p-4 space-y-2">
            
            <%= link_to admin_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-blue-400 rounded-xl border-l-4 border-transparent hover:border-blue-500 transition-all duration-300">
                <i data-feather="home" class="sidebar-icon text-blue-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Dashboard</span>
            </div>
            <% end %>

            <% if current_user.admin_profile.super? %>
              <%= link_to list_admins_dashboard_path do %>
              <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-purple-400 rounded-xl border-l-4 border-transparent hover:border-purple-500 transition-all duration-300">
                  <i data-feather="user" class="sidebar-icon text-purple-400 w-5 h-5 mr-3"></i>
                  <span class="font-medium">Admins</span>
              </div>
              <% end %>
            <% end %>

            <%= link_to club_verification_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-green-400 rounded-xl border-l-4 border-transparent hover:border-green-500 transition-all duration-300">
                <i data-feather="users" class="sidebar-icon text-green-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Verificação de Clubes</span>
            </div>
            <% end %>


            <%= link_to reports_dashboard_path do %>
            <div  class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-yellow-400 rounded-xl border-l-4 border-transparent hover:border-yellow-500 transition-all duration-300">
                <i data-feather="alert-triangle" class="sidebar-icon text-yellow-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Reports</span>
            </div>
            <% end %>

            <%= link_to bans_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 bg-slate-700 text-red-400 rounded-xl border-l-4 border-red-500 transition-all duration-300">
                <i data-feather="slash" class="sidebar-icon text-red-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Bans</span>
            </div>
            <% end %>

            <%= link_to root_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-gray-400 rounded-xl border-l-4 border-transparent hover:border-gray-400 transition-all duration-300">
                <i data-feather="arrow-left" class="sidebar-icon text-gray-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Página Inicial</span>
            </div>
            <% end %>
        </nav>


        <div class="p-4 border-t border-slate-700">
            <div class="flex items-center space-x-3">
                <% if current_user.admin_profile.profile_picture.attached? %>
                    <%= image_tag url_for(current_user.admin_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% end %>
                <div class="flex-1">
                        <p class="text-sm font-medium text-white"> <%= current_user.admin_profile.name %> </p>
                </div>
                <%= button_to destroy_user_session_path, method: :delete do %>
                    <i data-feather="log-out" class="text-slate-400 hover:text-red-400 cursor-pointer transition-colors"></i>
                <% end %>
            </div>
        </div>
</div>
<!-------------------------------------------------------------------------------- MAIN ------------------------------------------------------------------------->
    <div class="flex-1 p-8">

            <div class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-red-500 slide-in">Bans</h1>
                    <p class="text-slate-400 mt-1">Veja todos os utilizadores que foram banidos da plataforma, assim como o motivo e quem os baniu</p> 
                </div>
            </div>
            <br>

            <!---------------------------------------------------- PESQUISAS ---------------------------------------------------->
            <div class="flex items-center mb-6 gap-x-4">
                <%= form_with url: bans_dashboard_path, method: :get, local: true, id: "search-form" do %>
                    <div class="relative w-80">
                        <i data-feather="search" class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 w-4 h-4 pointer-events-none z-10"></i>
                        <%= text_field_tag :query, params[:query], placeholder: "Pesquisar Utilizadores Banidos", class: "bg-gray-800 border border-gray-700 rounded-lg pl-10 pr-10 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white", oninput: "clearTimeout(window.searchTimeout); window.searchTimeout = setTimeout(() => this.form.requestSubmit(), 1000); toggleClearButton(this)", id: "search-input" %>
                        <button type="button" id="clear-search" onclick="clearSearch()" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-white transition <%= 'hidden' unless params[:query].present? %>">
                            <i data-feather="x" class="w-4 h-4 text-red-400"></i>
                        </button>
                    </div>
                <% end %>

            </div>

            
<!-------------------------------------------------------------------------------- Admins ------------------------------------------------------------------------->

            <div class="mb-12">
                <% if !params[:query].present? or (params[:query].present? and @banned_users_count != 0) %>
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-xl font-bold text-red-400 flex items-center space-x-2">
                            <i data-feather="slash" class="w-6 h-6"></i>
                            <span>Utilizadores Banidos ( <%= @banned_users_count %> )</span>
                        </h3>

                    </div>
                <% end %>

                <% if params[:query].present? and @banned_users_count == 0 %>
                    <br>
                    <div class="flex justify-center items-center mb-8">
                        <div class="flex flex-col items-start">
                            <h1 class="text-2xl text-neutral-400 slide-in mx-auto">A pesquisa "<%= params[:query] %>" não retornou nenhum utilizador banido! </h1>
                        </div>
                    </div>
                <% end %>

                <% if @banned_users&.any? %>
                    <div class="grid grid-cols-4 justify-center gap-6">
                    <% @banned_users.each do |banned| %>
                            <% if banned.club? %>
                                <% banned_profile = banned.club_profile %>
                            <% elsif banned.player? %>
                                <% banned_profile = banned.player_profile %>
                            <% elsif banned.coach? %>
                                <% banned_profile = banned.coach_profile %>
                            <% elsif banned.user? %>
                                <% banned_profile = banned.user_profile %>
                            <% elsif banned.board? %>
                                <% banned_profile = banned.board_profile %>
                        <% end %>
                        <%
                            profile_path_banned = case
                                when banned.club?   then club_profile_path(banned_profile)
                                when banned.player? then player_profile_path(banned_profile)
                                when banned.coach?  then coach_profile_path(banned_profile)
                                when banned.board?  then board_profile_path(banned_profile)
                                when banned.user?   then user_profile_path(banned_profile)
                            end
                        %>
                        <div data-modal-toggle="bans-<%=banned.id%>" data-modal-target="bans-<%=banned.id%>" class="clickable bg-gray-800 border-l-4 border-red-400 rounded-xl overflow-hidden transition-all hover:scale-[1.01] hover:shadow-lg hover:shadow-primary/10 relative">
                                <div class="relative h-40 bg-gradient-to-r from-primary/20 to-secondary/20">
                                    <div class="relative w-full h-40 rounded-lg overflow-hidden shadow-lg">
                                        <% if !banned.user? %>
                                            <% if banned_profile.banner_picture.attached? %>
                                                <%= image_tag url_for(banned_profile.banner_picture), class: "w-full h-full object-cover" %>
                                            <% else %>
                                                <%= image_tag "default_banner.jpg", class: "w-full h-full object-cover" %>
                                            <% end %>
                                        <% else %>
                                            <% if banned_profile.banner.attached? %>
                                                <%= image_tag url_for(banned_profile.banner), class: "w-full h-full object-cover" %>
                                            <% else %>
                                                <%= image_tag "default_banner.jpg", class: "w-full h-full object-cover" %>
                                            <% end %>
                                        <% end %>
                                    </div>
                                    <div class="absolute top-20 left-4 w-32 h-32 rounded-full overflow-hidden border-4 border-white shadow-lg bg-gray-100 group">
                                        <% if banned_profile.profile_picture.attached? %>
                                            <%= image_tag url_for(banned_profile.profile_picture), class: "w-full h-full object-cover " %>
                                        <% else %>
                                            <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover " %>
                                        <% end %>
                                    </div>
                                </div>
                                <div class="p-4 pt-14 pb-4">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <h3 class="font-bold text-lg"> <%= banned_profile.name %> </h3>
                                            <p class="text-gray-400 text-sm"> Banido a: <%= l(banned.updated_at, format: :long, locale: :pt) %>
                                        </div>
                                    </div>
                                </div>
                        </div>

                    
                        <div id="bans-<%=banned.id%>" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
                            <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                                
                                <div class="flex justify-between items-center mb-6">
                                    <h2 class="text-2xl font-bold text-red-400">Banimento</h2>
                                    <button data-modal-hide="bans-<%=banned.id%>" class="text-slate-400 hover:text-white">
                                        <i data-feather="x"></i>
                                    </button>
                                </div>
                            <label class="block text-sm font-medium text-slate-300 mb-2 mt-4">Utilizador:</label>
                                <%= link_to profile_path_banned  do %>
                                <div class="bg-gray-800 border-l-4 border-red-400 rounded-xl overflow-hidden transition-all hover:scale-[1.01] hover:shadow-lg hover:shadow-primary/10 relative">
                                    <div class="relative h-24 w-full">
                                        <% if !banned.user? %>
                                            <% if banned_profile.banner.attached? %>
                                                <%= image_tag url_for(banned_profile.banner), class: "w-full h-full object-cover" %>
                                            <% else %>
                                                <%= image_tag "default_banner.jpg", class: "w-full h-full object-cover" %>
                                            <% end %>
                                        <% else %>
                                            <% if banned_profile.banner_picture.attached? %>
                                                <%= image_tag url_for(banned_profile.banner_picture), class: "w-full h-full object-cover" %>
                                            <% else %>
                                                <%= image_tag "default_banner.jpg", class: "w-full h-full object-cover" %>
                                            <% end %>
                                        <% end %>
                                        
                                    </div>

                                    <div class="bg-slate-700 px-4 pb-4 pt-10 relative">
                                        <div class="absolute -top-8 left-4 w-16 h-16 rounded-full overflow-hidden border-4 border-slate-700 shadow-lg">
                                            <% if banned_profile.profile_picture.attached? %>
                                                <%= image_tag url_for(banned_profile.profile_picture), class: "w-full h-full object-cover" %>
                                            <% else %>
                                                <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                            <% end %>
                                        </div>

                                        <div class="flex items-center justify-between">
                                            <span class="text-lg font-bold text-white"><%= banned_profile.name %></span>
                                        </div>
                                    </div>
                                </div>
                                <% end %>

                                    <label class="block text-sm font-medium text-slate-300 mb-2 mt-4">Banido Por:</label>
                                    <% user = User.find_by(id: banned.banned_by) %>
                                    <% admin = user.admin_profile %>
                                    <%= link_to admin_profile_path(admin) do %>
                                    <div class="bg-gray-800 border-l-4 border-red-400 rounded-xl overflow-hidden transition-all hover:scale-[1.01] hover:shadow-lg hover:shadow-primary/10 relative">
                                        <div class="relative h-24 w-full">
                                            <% if admin.banner_picture.attached? %>
                                                <%= image_tag url_for(admin.banner_picture), class: "w-full h-full object-cover" %>
                                            <% else %>
                                                <%= image_tag "default_banner.jpg", class: "w-full h-full object-cover" %>
                                            <% end %>
                                        </div>

                                        <div class="bg-slate-700 px-4 pb-4 pt-10 relative">
                                            <div class="absolute -top-8 left-4 w-16 h-16 rounded-full overflow-hidden border-4 border-slate-700 shadow-lg">
                                                <% if admin.profile_picture.attached? %>
                                                    <%= image_tag url_for(admin.profile_picture), class: "w-full h-full object-cover" %>
                                                <% else %>
                                                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                                <% end %>
                                            </div>

                                            <div class="flex items-center justify-between">
                                                <span class="text-lg font-bold text-white"><%= admin.name %></span>
                                            </div>
                                        </div>
                                    </div>
                                    <% end %>


                                <div class="mb-4 mt-4">
                                    <label class="block text-sm font-medium text-slate-300 mb-2 mt-4">Motivo do banimento:</label>
                                    <p class="text-sm text-white bg-slate-700 rounded-lg p-3"><%= banned.ban_reason %></p>
                                </div>

                                <button data-modal-target="unban-modal-<%banned.id%>" data-modal-toggle="unban-modal-<%banned.id%>" class="mt-2 w-full bg-yellow-600 hover:bg-yellow-700 disabled:opacity-40 text-white font-bold py-2 px-4 rounded-lg transition-colors">
                                    Revogar Banimento
                                </button>

                            </div>
                        </div>

                        <div id="unban-modal-<%banned.id%>" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50">
                            <div class="bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4 shadow-2xl border border-gray-700 transform transition-all">
                                <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-red-900 rounded-full">
                                    <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                    </svg>
                                </div>
                                <h3 class="text-xl font-semibold text-white text-center mb-2">Confirmar ação</h3>
                                <p class="text-gray-300 text-center mb-6"> Tem a certeza revogar o banimento a este utilizador? </b>  </p>
                                <div class="flex gap-3">
                                    <button data-modal-hide="unban-modal-<%banned.id%>" class="flex-1 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium">
                                        Cancelar
                                    </button>
                                    <%= button_to unban_user_path(banned), method: :patch, 
                                        class: "flex-1 bg-red-600 hover:bg-red-800 text-white font-bold py-2 px-4 rounded-lg transition-colors" do %>
                                        Revogar Banimento
                                    <% end %>
                                </div>
                            </div>
                        </div>
                    
                    <% end %>

                <% end %>

                </div> 

                <% if @banned_users.total_pages > 1 %>
                <div class="mt-8 flex justify-end">
                    <div class="flex flex-col items-end gap-3">               

                    <div class="flex items-center gap-2">
                        <% if @banned_users.prev_page %>
                        <%= link_to bans_dashboard_path(query: params[:query], bans_page: @banned_users.prev_page), class: "flex items-center gap-2 px-4 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white rounded-lg border border-gray-700 transition-all duration-200 font-medium" do %>
                            <i data-feather="chevron-left" class="w-4 h-4"></i>
                            <span>Anterior</span>
                        <% end %>
                        <% else %>
                        <div class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/50 text-gray-600 rounded-lg border border-gray-700/50 cursor-not-allowed font-medium">
                            <i data-feather="chevron-left" class="w-4 h-4"></i>
                            <span>Anterior</span>
                        </div>
                        <% end %>

                        <div class="flex items-center gap-1">
                        <% (1..@banned_users.total_pages).each do |page| %>
                            <% if page == @banned_users.current_page %>
                            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-red-500 text-white font-bold border-2 border-red-300 shadow-lg">
                                <%= page %>
                            </div>
                            <% else %>
                            <%= link_to page, bans_dashboard_path(query: params[:query], bans_page: page), class: "w-10 h-10 flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white border border-gray-700 transition-all duration-200 font-medium" %>
                            <% end %>
                        <% end %>
                        </div>

                        <% if @banned_users.next_page %>
                        <%= link_to bans_dashboard_path(query: params[:query], bans_page: @banned_users.next_page), class: "flex items-center gap-2 px-4 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white rounded-lg border border-gray-700 transition-all duration-200 font-medium" do %>
                            <span>Seguinte</span>
                            <i data-feather="chevron-right" class="w-4 h-4"></i>
                        <% end %>
                        <% else %>
                        <div class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/50 text-gray-600 rounded-lg border border-gray-700/50 cursor-not-allowed font-medium">
                            <span>Seguinte</span>
                            <i data-feather="chevron-right" class="w-4 h-4"></i>
                        </div>
                        <% end %>
                    </div>
                    </div>
                </div>

                <% elsif !@banned_users&.any? and !params[:query].present? %>
                    <div class="flex justify-center items-center mb-8">
                        <div class="flex flex-col items-start">
                            <h1 class="text-2xl text-neutral-400 slide-in mx-auto">Ainda não há nenhum utilizador banido!</h1>
                        </div>
                    </div>
                <% end %>
                
            </div>
            
    </div>

<script>
    feather.replace()
</script>

<!-- Configuração da cor principal e secundária do tailwind -->

