<body class="min-h-screen flex text-white bg-gray-900">
<!---------------------------------------------------- NOME E LOGO DO CLUBE ---------------------------------------------------->
    <div class="w-64 bg-slate-800 shadow-xl min-h-screen flex flex-col border-r border-slate-700">
    <!-- Logo e nome do clube -->
        <div class="p-6 border-b border-slate-700">
            <div class="flex items-center justify-center mb-3">
                
                <% if (current_user.club? and current_user.club_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.club_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% elsif (current_user.board? && current_user.board_profile.club_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.board_profile.club_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-20 h-20 rounded-full border-1" %>
                <% end %>

                
            </div>
            <h1 class="text-lg font-bold text-center text-white">
                <% if current_user.club? %>
                    <%= current_user.club_profile.name %>
                <% elsif current_user.board? %>
                    <%= current_user.board_profile.club_profile.name %>
                <% end %>
            </h1>
        </div>
<!---------------------------------------------------- OPÇÕES DO SIDEBAR ---------------------------------------------------->
        <nav class="flex-1 p-4 space-y-2">
            
            <%= link_to club_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-blue-400 rounded-xl border-l-4 border-transparent hover:border-blue-500 transition-all duration-300">
                <i data-feather="home" class="sidebar-icon text-blue-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Dashboard</span>
            </div>
            <% end %>

            <%= link_to club_teams_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-green-400 rounded-xl border-l-4 border-transparent hover:border-green-500 transition-all duration-300">
                <i data-feather="users" class="sidebar-icon text-green-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Equipas</span>
            </div>
            <% end %>


            <%= link_to club_finances_dashboard_path do %>
            <div  class="sidebar-item flex items-center px-4 py-3 bg-slate-700 text-yellow-400 rounded-xl border-l-4 border-yellow-500 transition-all duration-300">
                <i data-feather="dollar-sign" class="sidebar-icon text-yellow-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Finanças</span>
            </div>
            <% end %>


            <%= link_to club_infrastructures_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-orange-400 rounded-xl border-l-4 border-transparent hover:border-orange-500 transition-all duration-300">
                <i data-feather="map-pin" class="sidebar-icon text-orange-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Infraestruturas</span>
            </div>
            <% end %>

            <%= link_to club_equipment_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-rose-400 rounded-xl border-l-4 border-transparent hover:border-rose-300 transition-all duration-300">
                <i data-feather="clipboard" class="sidebar-icon text-rose-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Material</span>
            </div>
            <% end %>

            <%= link_to club_board_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-rose-900 rounded-xl border-l-4 border-transparent hover:border-rose-950 transition-all duration-300">
                <i data-feather="settings" class="sidebar-icon text-rose-900 w-5 h-5 mr-3"></i>
                <span class="font-medium">Membros da Direção</span>
            </div>
            <% end %>

            <%= link_to club_invitations_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-purple-500 rounded-xl border-l-4 border-transparent hover:border-purple-950 transition-all duration-300">
                <i data-feather="mail" class="sidebar-icon text-purple-500 w-5 h-5 mr-3"></i>
                <span class="font-medium">Convites</span>
            </div>
            <% end %>

            <%= link_to root_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-gray-400 rounded-xl border-l-4 border-transparent hover:border-gray-400 transition-all duration-300">
                <i data-feather="arrow-left" class="sidebar-icon text-gray-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Página Inicial</span>
            </div>
            <% end %>
        </nav>


        <div class="p-4 border-t border-slate-700">
            <div class="flex items-center space-x-3">
                <% if (current_user.club? and current_user.club_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.club_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% elsif (current_user.board? and current_user.board_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.board_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% end %>
                <div class="flex-1">
                    <% if current_user.club? %>
                        <p class="text-sm font-medium text-white"> <%= current_user.club_profile.name %> </p>
                    <% elsif current_user.board? %>
                        <p class="text-sm font-medium text-white"> <%= current_user.board_profile.name %> </p>
                    <% end %>
                </div>
                <%= button_to destroy_user_session_path, method: :delete do %>
                    <i data-feather="log-out" class="text-slate-400 hover:text-red-400 cursor-pointer transition-colors"></i>
                <% end %>
            </div>
        </div>
</div>
<!---------------------------------------------------- MAIN CONTENT ---------------------------------------------------->
    <div class="flex-1 p-8 overflow-auto">
        <% if !@club_profile.verified? %>
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold slide-in text-yellow-400">Finanças</h1>
                <p class="text-slate-400 mt-1"> Adicione os lucros e despesas e trate de toda a gestão financeira por mês </p>
            </div>
        </div>
        <% end %>
        <% if @club_profile.verified? %>
        <!-- Month Navigator -->
        <div class="flex justify-center items-center mb-8">

            <%= link_to club_finances_dashboard_path(start_date: (@first_of_month - 1.month).to_s), class: "px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg" do %>
                <i data-feather="chevron-left" class="w-8 h-8 text-slate-400"></i>
            <% end %>

            <h1 class="text-4xl font-bold mx-8 text-white tracking-wider">  <%= @current_month %> <%= @current_year %> </h1>

            
            <%= link_to club_finances_dashboard_path(start_date: (@first_of_month + 1.month).to_s), class: "px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg" do %>
                <i data-feather="chevron-right" class="w-8 h-8 text-slate-400"></i>
            <% end %>
            
        </div>
    
        <!-- Linha de Separador -->
        <hr class="border-slate-700 my-8">

        <!-- Caixas de Info de Valores -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
            <!-- Carteira -->
            <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700 flex flex-col">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-white">Carteira</h3>
                    <i data-feather="briefcase" class="text-blue-400"></i>
                </div>
                
                <% if @club_balance.nil? %>
                    <div id="wallet-empty-view" class="flex-grow flex items-center justify-center">
                        <button data-modal-toggle="modal-start-money" data-modal-target="modal-start-money" class="add-money-trigger w-full bg-slate-700 hover:bg-slate-600 text-slate-300 px-4 py-3 rounded-lg font-medium transition-colors opacity-80 hover:opacity-100">
                            Adicionar Dinheiro à Conta
                        </button>
                    </div>
                    
                <% else %>
                    <div id="wallet-balance-view" class="flex-grow flex flex-col justify-between ">
                        <div class="flex-grow">
                            <div class="flex items-center mb-1">
                                <p id="wallet-balance-amount" class="text-3xl font-bold text-white">
                                    <%= number_to_currency(@club_balance.value, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %>
                                </p>
                            </div>
                            <p class="text-sm text-slate-400">Valor em caixa</p>
                        </div>
                    </div>
                <% end %>
            </div>



            <!-- Receitas -->
            <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-white">Receitas do Mês</h3>
                    <i data-feather="arrow-up-circle" class="text-green-400"></i>
                </div>
                <p class="text-3xl font-bold text-green-400">+ <%= number_to_currency(@month_incomes_total, unit: "€", separator: ",", delimiter: ".", format: "%n %u") || 0 %></p>
                <p class="text-sm text-slate-400">Total de entradas </p>
            </div>

            <!-- Despesas -->
            <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
                <div class="flex items-center justify-between mb-4">
                    <h3 class="text-lg font-semibold text-white">Despesas do Mês</h3>
                    <i data-feather="arrow-down-circle" class="text-red-400"></i>
                </div>
        <p class="text-3xl font-bold text-red-400">- <%= number_to_currency(@month_expenses_total, unit: "€", separator: ",", delimiter: ".", format: "%n %u") || 0 %> </p>
                <p class="text-sm text-slate-400">Total de saídas</p>
            </div>
        </div>

        <!-- Linha de Separador -->
        <hr class="border-slate-700 my-8">

        <h3 class="text-3xl font-semibold text-yellow-300 mb-4">Receitas/Despesas</h3>

        <!-- Searchbar e Botões de Add-->
        <div class="flex justify-between items-center mb-8">
            <!-- Searchbar -->
            <% if @club_balance %>
                <%= form_with url: club_finances_dashboard_path, method: :get, local: true, id: "search-form" do %>
                    <div class="relative w-80">
                        <i data-feather="search" class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 w-4 h-6 pointer-events-none z-10"></i>
                        <%= text_field_tag :query,
                            params[:query],
                            placeholder: "Pesquisar Transações",
                            class: "bg-gray-800 border border-gray-700 rounded-lg pl-10 pr-10 py-2 w-full focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent",
                            oninput: "clearTimeout(window.searchTimeout); window.searchTimeout = setTimeout(() => this.form.requestSubmit(), 1000); toggleClearButton(this)",
                            id: "search-input" %>
                        <button type="button" id="clear-search" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-white transition <%= 'hidden' unless params[:query].present? %>" onclick="clearSearch()">
                            <i data-feather="x" class="w-4 h-4 text-red-400"></i>
                        </button>
                    </div>
                <% end %>
            <% end %>

            <!-- Botões de Add Receitas/Despesas -->
            <div class="flex space-x-4">
                <% if @club_balance %>
                    <button data-modal-toggle="modal-add-income" data-modal-target="modal-add-income" title="Adicionar Receita" class="p-2 bg-green-600 hover:bg-green-700 rounded-lg text-white transition-colors">
                        <i data-feather="plus-circle"></i>
                    </button>
                    <button data-modal-toggle="modal-add-expense" data-modal-target="modal-add-expense" title="Adicionar Despesa" class="p-2 bg-red-600 hover:bg-red-700 rounded-lg text-white transition-colors">
                        <i data-feather="plus-circle"></i>
                    </button>
                <% end %>
            </div>
        </div>

        <!-- Lista Receitas/Despesas -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-x-8">
            <!-- Coluna de Receitas -->
            <div class="md:pr-4">
                <h3 class="text-2xl font-semibold text-green-400 mb-4">Receitas</h3>
                <div class="pr-2 max-h-72 overflow-y-auto no-scrollbar" id="revenue-scroll-container">
                    <!-- Exemplos de Receitas -->
                    <div class="space-y-4" id="revenue-list">
                        <% if @month_incomes.any? %>
                            <% @month_incomes.each do |income| %>
                                <div class="flex justify-between items-center bg-slate-800 p-3 rounded-lg border border-slate-700">
                                    <div>
                                        <p class="font-medium text-white"> <%= income.description %> </p>
                                        <p class="text-sm text-slate-400"> <%= income.date.strftime("%d/%m/%Y") %> </p>
                                    </div>
                                    <span class="font-bold text-green-400"> <%= number_to_currency(income.value, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %> </span>
                                </div>
                            <% end %>
                        <% elsif params[:query].present? %>
                            <p id="end-expenses-msg" class="text-slate-500 text-xl text-center "> A pesquisa "<%= params[:query] %>" não retornou nenhuma receita</p>
                        <% elsif !params[:query].present? %>
                            <p id="end-expenses-msg" class="text-slate-500 text-xl text-center "> Ainda não há nenhuma receita neste mês </p>
                        <% end %>
                    </div>
                </div>
                <div class="mt-4 text-center">
                    <button id="load-more-revenues" class="text-blue-400 hover:text-blue-300 text-sm font-medium hidden">Carregar mais</button>
                    <p id="end-revenues-msg" class="text-slate-500 text-sm hidden">Não existem mais receitas</p>
                </div>
            </div>

            <!-- Coluna de Despesas -->
            <div class="border-t border-slate-700 md:border-t-0 md:border-l md:border-slate-700 md:pl-8 pt-8 md:pt-0 mt-8 md:mt-0">
                <h3 class="text-2xl font-semibold text-red-400 mb-4">Despesas</h3>
                <div class="pr-2 max-h-72 overflow-y-auto no-scrollbar" id="expense-scroll-container">
                    <!-- Exemplos de Despesas -->
                    <div class="space-y-4" id="expense-list">
                        <% if @month_expenses.any? %>
                            <% @month_expenses.each do |expense| %>
                                <div class="flex justify-between items-center bg-slate-800 p-3 rounded-lg border border-slate-700">
                                    <div>
                                        <p class="font-medium text-white"> <%= expense.description %> </p>
                                        <p class="text-sm text-slate-400"> <%= expense.date.strftime("%d/%m/%Y") %> </p>
                                    </div>
                                    <span class="font-bold text-red-400">- <%= number_to_currency(expense.value, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %> </span>
                                </div>
                            <% end %>
                        <% elsif params[:query].present? %>
                            <p id="end-expenses-msg" class="text-slate-500 text-xl text-center "> A pesquisa "<%= params[:query] %>" não retornou nenhuma despesa</p>
                        <% elsif !params[:query].present? %>
                            <p id="end-expenses-msg" class="text-slate-500 text-xl text-center "> Ainda não há nenhuma despesa neste mês </p>
                        <% end %>
                    </div>
                </div>
                <div class="mt-4 text-center">
                    <button id="load-more-expenses" class="text-blue-400 hover:text-blue-300 text-sm font-medium hidden">Carregar mais</button>
                    <p id="end-expenses-msg" class="text-slate-500 text-sm hidden">------------------------- FIM     -------------------------</p>
                </div>
            </div>
        </div>
    <% else %>
    <div class="flex justify-center items-center mb-8">
            <div class="flex flex-col items-start">
            <% if @club_profile.verification_pending? %>
                <div class="flex justify-center mt-16 px-4">
                    <div class="flex flex-col items-center p-8 text-yellow-100 rounded-2xl bg-yellow-700/20 border border-yellow-600/40 text-center max-w-md w-full shadow-lg">
                        <div class="w-16 h-16 rounded-full bg-yellow-600/30 flex items-center justify-center mb-4">
                            <svg class="w-8 h-8 text-yellow-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
                            </svg>
                        </div>
                        <span class="text-xl font-bold mb-2">Verificação Pendente</span>
                        <span class="text-sm text-yellow-200/80">Esta secção será desbloqueada uma vez que o clube esteja verificado</span>
                    </div>
                </div>
            <% elsif @club_profile.verification_rejected? %>
                <div class="flex justify-center mt-16 px-4">
                    <div class="flex flex-col items-center p-8 text-red-100 rounded-2xl bg-red-700/20 border border-red-600/40 text-center max-w-md w-full shadow-lg">
                        <div class="w-16 h-16 rounded-full bg-red-600/30 flex items-center justify-center mb-4">
                            <svg class="w-8 h-8 text-red-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
                            </svg>
                        </div>
                        <span class="text-xl font-bold mb-2">Verificação Rejeitada</span>
                        <span class="text-sm text-red-200/80">Esta secção será desbloqueada uma vez que o clube esteja verificado</span>
                    </div>
                </div>
            <% end %>
            </div>  
        </div>
<% end %>

        <!-- Modal Add Receitas -->
        <div id="modal-add-income" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-green-400">Adicionar Receita</h2>
                    <button data-modal-hide="modal-add-income" class="text-slate-400 hover:text-white">
                        <i data-feather="x"></i>
                    </button>
                </div>  
                    <%= form_with url: club_incomes_path, method: :post, data: { turbo: false } do |f| %>
                        <div class="mb-4">
                            <label for="revenue-amount" class="block text-sm font-medium text-slate-300 mb-2">Valor</label>
                            <%= f.number_field :value, name: "club_income[value]", step:"0.01", min: 0, class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "0,00 €" %>

                        </div>
                        <div class="mb-4">
                            <label for="revenue-description" class="block text-sm font-medium text-slate-300 mb-2">Descrição</label>
                            <%= f.text_field :description, name: "club_income[description]", class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "Ex: Venda de Bilhetes" %>
                        </div>
                        <div class="mb-6">
                            <label for="revenue-date" class="block text-sm font-medium text-slate-300 mb-2">Data</label>
                            <%= f.date_field :date, name: "club_income[date]", class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500" %>
                        </div>
                        <%= f.submit "Confirmar", class:"w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-lg transition-colors"  %>
                    <% end %>
            </div>
        </div>

        <!-- Modal Add Despesas -->
        <div id="modal-add-expense" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-red-400">Adicionar Despesa</h2>
                    <button data-modal-hide="modal-add-expense" class="text-slate-400 hover:text-white">
                        <i data-feather="x"></i>
                    </button>
                </div>
                <%= form_with url: club_expenses_path, method: :post, data: { turbo: false } do |f| %>
                    <div class="mb-4">
                        <label for="revenue-amount" class="block text-sm font-medium text-slate-300 mb-2">Valor</label>
                        <%= f.number_field :value, name: "club_expense[value]", step:"0.01", min: 0, class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "0,00 €" %>

                    </div>
                    <div class="mb-4">
                        <label for="revenue-description" class="block text-sm font-medium text-slate-300 mb-2">Descrição</label>
                        <%= f.text_field :description, name: "club_expense[description]", class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "Ex: Compra de Material" %>
                    </div>
                    <div class="mb-6">
                        <label for="revenue-date" class="block text-sm font-medium text-slate-300 mb-2">Data</label>
                        <%= f.date_field :date, name: "club_expense[date]", class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500" %>
                    </div>
                    <%= f.submit "Confirmar", class:"w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-lg transition-colors"  %>
                <% end %>
            </div>
        </div>

        <!-- Modal Add Dinheiro -->
        <div id="modal-start-money" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
            <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                <div class="flex justify-between items-center mb-6">
                    <h2 class="text-2xl font-bold text-blue-400">Adicionar saldo à conta</h2>
                    <button data-modal-hide="modal-start-money" class="text-slate-400 hover:text-white">
                        <i data-feather="x"></i>
                    </button>
                </div>
                <%= form_with url: club_balances_path, method: :post, data: { turbo: false } do |f| %>
                    <div class="mb-6">
                        <label class="block text-sm font-medium text-slate-300 mb-2">Quantia</label>
                        <%= f.number_field :value, step: 0.01, min: 0, name: "club_balance[value]", id: "balance-value-input", class: "w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "0,00 €", required: true %>
                    </div>
                    <button type="button" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded-lg transition-colors cursor-pointer" data-modal-toggle="modal-confirmar-start-money" data-modal-target="modal-confirmar-start-money"> <p > Adicionar <p> </button>
                    
            </div>

            <div id="modal-confirmar-start-money" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 modal">
                <div class="bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4 shadow-2xl border border-gray-700 transform transition-all">
                    <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-red-900 rounded-full">
                        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-semibold text-white text-center mb-2">Confirmar ação</h3>
                    <p class="text-gray-300 text-center mb-6">Tem a certeza que pretende adicionar <span id="confirmar-valor" class="font-bold text-white"></span>? Esta ação é permanente e não pode ser alterada no futuro</p>
                    <div class="flex gap-3">
                        <button type="button" data-modal-hide="modal-confirmar-start-money" class="flex-1 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium">
                            Cancelar
                        </button>
                        <%= f.submit "Confirmar", class: "w-full bg-green-600 hover:bg-green-700 text-white font-bold py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
                <% end %>
                    </div>
                </div>
            </div>


        </div>
    </div>
    
    <script>
            feather.replace();

            document.querySelector('[data-modal-target="modal-confirmar-start-money"]')?.addEventListener('click', () => {
                const valor = document.getElementById('balance-value-input').value;
                const valorFormatado = parseFloat(valor).toLocaleString('pt-PT', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
                document.getElementById('confirmar-valor').innerText = valorFormatado + ' €';
            });

                function toggleClearButton(input) {
                    const clearBtn = document.getElementById('clear-search');
                    if (input.value.length > 0) {
                        clearBtn.classList.remove('hidden');
                    } else {
                        clearBtn.classList.add('hidden');
                    }
                }

                function clearSearch() {
                    const input = document.getElementById('search-input');
                    input.value = '';
                    document.getElementById('clear-search').classList.add('hidden');
                    document.getElementById('search-form').requestSubmit();
                }
    </script>

</body>

<style>
    .sidebar-icon {
        transition: all 0.3s ease;
    }
    
    .sidebar-item:hover .sidebar-icon {
        transform: translateX(5px);
    }

    /* Hide scrollbar for Chrome, Safari and Opera */
    .no-scrollbar::-webkit-scrollbar {
        display: none;
    }

    /* Hide scrollbar for IE, Edge and Firefox */
    .no-scrollbar {
        -ms-overflow-style: none;  /* IE and Edge */
        scrollbar-width: none;  /* Firefox */
    }

    /* Remover setas dos inputs number */
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { 
        -webkit-appearance: none; 
        margin: 0; 
    }
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>