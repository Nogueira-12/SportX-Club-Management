        feather.replace();
    </script>


    <script>
        document.addEventListener('DOMContentLoaded', function() {
            
            const CtPicInput = document.getElementById('ct-picture');
            const CtPicPreview = document.getElementById('ct-picture-preview');
            const RemoveCtPicBtn = document.getElementById('remove-ct-picture-btn');
            const originalBannerSrc = CtPicPreview ? CtPicPreview.src : '';

            if (CtPicInput && CtPicPreview) {
            CtPicInput.addEventListener('change', (e) => {
                const file = e.target.files[0];
                if (file && file.type.startsWith('image/')) {
                const reader = new FileReader();
                reader.onload = (ev) => {
                    CtPicPreview.src = ev.target.result;
                    RemoveCtPicBtn.classList.remove('hidden');
                };
                reader.readAsDataURL(file);
                }
            });

            CtPicPreview.addEventListener('click', () => {
                CtPicInput.click();
            });

            if (RemoveCtPicBtn) {
                RemoveCtPicBtn.addEventListener('click', (e) => {
                e.stopPropagation();
                CtPicInput.value = '';
                CtPicPreview.src = originalBannerSrc;
                RemoveCtPicBtn.classList.add('hidden');
                });
            }
            }
        });


        function toggleClearButton(input) {
            const clearBtn = document.getElementById('clear-search');
            if (input.value.length > 0) {
                clearBtn.classList.remove('hidden');
            } else {
                clearBtn.classList.add('hidden');
            }
        }

        function clearSearch() {
            const input = document.getElementById('search-input');
            input.value = '';
            document.getElementById('clear-search').classList.add('hidden');
            document.getElementById('search-form').requestSubmit();
        }
    </script>
    </body>
