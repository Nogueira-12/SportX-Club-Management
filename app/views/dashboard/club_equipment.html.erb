    <body class="min-h-screen flex text-white bg-gray-900">
    <!---------------------------------------------------- NOME E LOGO DO CLUBE ---------------------------------------------------->
        <div class="w-64 bg-slate-800 shadow-xl min-h-screen flex flex-col border-r border-slate-700">
        <!-- Logo e nome do clube -->
            <div class="p-6 border-b border-slate-700">
                <div class="flex items-center justify-center mb-3">
                    
                    <% if (current_user.club? and current_user.club_profile.profile_picture.attached?) %>
                        <%= image_tag url_for(current_user.club_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                    <% elsif (current_user.board? && current_user.board_profile.club_profile.profile_picture.attached?) %>
                        <%= image_tag url_for(current_user.board_profile.club_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                    <% else %>
                        <%= image_tag "default_pp.jpg", class: "w-20 h-20 rounded-full border-1" %>
                    <% end %>

                    
                </div>
                <h1 class="text-lg font-bold text-center text-white"> <%= current_user.club_profile.name %> </h1>
            </div>
    <!---------------------------------------------------- OPÇÕES DO SIDEBAR ---------------------------------------------------->
            <nav class="flex-1 p-4 space-y-2">
                
                <%= link_to club_dashboard_path do %>
                <div class="sidebar-item flex items-center px-4 py-3 hover:bg-slate-700 text-slate-300 hover:text-blue-400 rounded-xl border-l-4 hover:border-blue-500 border-transparent transition-all duration-300">
                    <i data-feather="home" class="sidebar-icon text-blue-400 w-5 h-5 mr-3"></i>
                    <span class="font-medium">Dashboard</span>
                </div>
                <% end %>

                <%= link_to club_teams_dashboard_path do %>
                <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-green-400 rounded-xl border-l-4 border-transparent hover:border-green-500 transition-all duration-300">
                    <i data-feather="users" class="sidebar-icon text-green-400 w-5 h-5 mr-3"></i>
                    <span class="font-medium">Equipas</span>
                </div>
                <% end %>


                <%= link_to club_finances_dashboard_path do %>
                <div  class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-yellow-400 rounded-xl border-l-4 border-transparent hover:border-yellow-500 transition-all duration-300">
                    <i data-feather="dollar-sign" class="sidebar-icon text-yellow-400 w-5 h-5 mr-3"></i>
                    <span class="font-medium">Finanças</span>
                </div>
                <% end %>


                <%= link_to club_infrastructures_dashboard_path do %>
                <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-orange-400 rounded-xl border-l-4 border-transparent hover:border-orange-500 transition-all duration-300">
                    <i data-feather="map-pin" class="sidebar-icon text-orange-400 w-5 h-5 mr-3"></i>
                    <span class="font-medium">Infraestruturas</span>
                </div>
                <% end %>

                <%= link_to club_equipment_dashboard_path do %>
                <div class="sidebar-item flex items-center px-4 py-3 bg-slate-700 text-rose-400 rounded-xl border-l-4 border-rose-300 transition-all duration-300">
                    <i data-feather="clipboard" class="sidebar-icon text-rose-400 w-5 h-5 mr-3"></i>
                    <span class="font-medium">Material</span>
                </div>
                <% end %>

                <%= link_to club_board_dashboard_path do %>
                <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-rose-900 rounded-xl border-l-4 border-transparent hover:border-rose-950 transition-all duration-300">
                    <i data-feather="settings" class="sidebar-icon text-rose-900 w-5 h-5 mr-3"></i>
                    <span class="font-medium">Membros da Direção</span>
                </div>
                <% end %>

                <%= link_to club_invitations_dashboard_path do %>
                <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-purple-500 rounded-xl border-l-4 border-transparent hover:border-purple-950 transition-all duration-300">
                    <i data-feather="mail" class="sidebar-icon text-purple-500 w-5 h-5 mr-3"></i>
                    <span class="font-medium">Convites</span>
                </div>
                <% end %>

                <%= link_to root_path do %>
                <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-gray-400 rounded-xl border-l-4 border-transparent hover:border-gray-400 transition-all duration-300">
                    <i data-feather="arrow-left" class="sidebar-icon text-gray-400 w-5 h-5 mr-3"></i>
                    <span class="font-medium">Página Inicial</span>
                </div>
                <% end %>
            </nav>

            <div class="p-4 border-t border-slate-700">
                <div class="flex items-center space-x-3">
                    <% if (current_user.club? and current_user.club_profile.profile_picture.attached?) %>
                        <%= image_tag url_for(current_user.club_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                    <% elsif (current_user.board? and current_user.profile_picture.attached?) %>
                        <%= image_tag url_for(current_user.board_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                    <% else %>
                        <%= image_tag "default_pp.jpg", class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                    <% end %>
                    <div class="flex-1">
                        <% if current_user.club? %>
                            <p class="text-sm font-medium text-white"> <%= current_user.club_profile.name %> </p>
                        <% elsif current_user.board? %>
                            <p class="text-sm font-medium text-white"> <%= current_user.board_profile.name %> </p>
                        <% end %>
                    </div>
                    <%= button_to destroy_user_session_path, method: :delete do %>
                        <i data-feather="log-out" class="text-slate-400 hover:text-red-400 cursor-pointer transition-colors"></i>
                    <% end %>
                </div>
            </div>
    </div>

    <!---------------------------------------------------- MAIN CONTENT ---------------------------------------------------->
        <div class="flex-1 p-8">

                <div class="flex justify-between items-center mb-8">
                    <div>
                        <h1 class="text-3xl font-bold  text-rose-400 slide-in">Materiais</h1>
                        <p class="text-slate-400 mt-1">Controle stocks, registe adições e remoções de materiais, organize por equipa ou modalidade e acompanhe tudo de forma simples</p> 
                    </div>
                </div>
<% if @club_profile.verified? %>

    <% if !@club_profile.has_no_sports? %>

            <div class="flex items-center justify-between mb-6">
                <h3 class="text-xl font-bold text-rose-400 flex items-center space-x-2">
                    <i data-feather="clipboard" class="w-6 h-6"></i>
                    <% if @selected_sport == 'Geral' %>
                        <span>Materiais ( <%= @num_geral_materials  %> )</span>
                    <% elsif @selected_sport == 'Futebol' %>
                        <span>Materiais ( <%= @num_football_materials %> )</span>
                    <% elsif @selected_sport == 'Andebol' %>
                        <span>Materiais ( <%= @num_handball_materials %> )</span>
                    <% end %>
                </h3>
            <% if !@club_profile.has_no_sports? %>
                <div class="flex items-center gap-4">
                    <button data-modal-target="modal-add-material" data-modal-toggle="modal-add-material" class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded-lg flex items-center space-x-2 transition-all duration-200 transform hover:scale-105">
                        <i data-feather="plus" class="w-4 h-4"></i>
                    </button>
                </div>
            <% end %>
                
            </div>

    <!---------------------------------------------------- PESQUISAS ---------------------------------------------------->
            <div class="flex  items-center mb-6 gap-x-4">
                <%= form_with url: club_equipment_dashboard_path, method: :get, local: true, id: "search-form" do %>
                    <%= hidden_field_tag :sport, @selected_sport %>
                    <div class="relative w-80">
                        <i data-feather="search" class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 w-4 h-4 pointer-events-none z-10"></i>
                        <%= text_field_tag :query, params[:query], placeholder: "Pesquisar Materiais", class: "bg-gray-800 border border-gray-700 rounded-lg pl-10 pr-10 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white", oninput: "clearTimeout(window.searchTimeout); window.searchTimeout = setTimeout(() => this.form.requestSubmit(), 1000); toggleClearButton(this)", id: "search-input" %>
                        <button type="button" id="clear-search" onclick="clearSearch()" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-white transition <%= 'hidden' unless params[:query].present? %>">
                            <i data-feather="x" class="w-4 h-4 text-red-400"></i>
                        </button>
                    </div>
                <% end %>
            <% if @club_profile.has_both_sports? %>
                <%= link_to club_equipment_dashboard_path(sport: 'Geral') do %>
                    <button class="px-6 py-2 rounded-full border transition-all duration-200 <%= @selected_sport == 'Geral' ? 'bg-blue-600 border-blue-500 text-white' : 'bg-gray-800 border-gray-600 text-gray-300 hover:border-blue-500 hover:text-blue-400 hover:bg-blue-500/10' %>">
                        Geral
                    </button>
                <% end %>
            <% end %>
            <% if @club_profile.has_football? %>
                <%= link_to club_equipment_dashboard_path(sport: 'Futebol') do %>
                    <button class="px-6 py-2 rounded-full border transition-all duration-200 <%= @selected_sport == 'Futebol' ? 'bg-blue-600 border-blue-500 text-white' : 'bg-gray-800 border-gray-600 text-gray-300 hover:border-blue-500 hover:text-blue-400 hover:bg-blue-500/10' %>">
                        Futebol
                    </button>
                <% end %>
            <% end %>
            <% if @club_profile.has_handball? %>
                <%= link_to club_equipment_dashboard_path(sport: 'Andebol') do %>
                    <button class="px-6 py-2 rounded-full border transition-all duration-200 <%= @selected_sport == 'Andebol' ? 'bg-blue-600 border-blue-500 text-white' : 'bg-gray-800 border-gray-600 text-gray-300 hover:border-blue-500 hover:text-blue-400 hover:bg-blue-500/10' %>">
                        Andebol
                    </button>
                <% end %>
            <% end %>

            </div>

    <!---------------------------------------------------- MATERIAIS ---------------------------------------------------->
                <div class="grid grid-cols-4 justify-center gap-6">
                <% if @selected_sport == 'Geral' %>
                    <% if @geral_materials.any? %>
                        <% @geral_materials.each do |geral| %>
                            <div data-modal-target="modal-edit-material-geral-<%=geral.id%>" data-modal-toggle="modal-edit-material-geral-<%=geral.id%>" class="bg-gray-800 border border-gray-700 rounded-xl overflow-hidden transition-all hover:scale-[1.01] hover:shadow-lg hover:shadow-primary/10 clickable">
                                <% if geral.image.attached? %>
                                    <div class="relative h-40 bg-gray-900 flex items-center justify-center">
                                        <%= image_tag url_for(geral.image), class: "w-full h-full object-cover" %>
                                    </div>
                                <% else %>
                                    <div class="relative h-40 bg-gray-900 flex items-center justify-center">
                                        <i data-feather="box" class="w-16 h-16 text-gray-300"></i>
                                    </div>
                                <% end %>
                                <div class="p-4">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <h3 class="font-bold text-lg"> <%= geral.name %> </h3>
                                            <p class="text-gray-400 text-sm"> <%= geral.description %> </p>
                                        </div>
                                        <div>
                                            <p class="text-md text-gray-400">Qtd.</p>
                                            <p class="font-medium text-center"> <%= geral.quantity %> </p>
                                        </div>
                                    </div>
                                </div>
                            </div>


                            <div id="modal-edit-material-geral-<%=geral.id%>" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
                                <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                                    <div class="flex justify-between items-center mb-6">
                                        <h2 class="text-2xl font-bold text-yellow-400">Editar Material</h2>
                                        <button data-modal-hide="modal-edit-material-geral-<%=geral.id%>" class="text-slate-400 hover:text-white">
                                            <i data-feather="x"></i>
                                        </button>
                                    </div>

                                        <%= form_with url: club_material_path(geral), method: :patch, multipart: true,  data: { turbo: false } do |f| %>

                                            <div class="mb-4">
                                                <label class="block text-sm font-medium text-slate-300 mb-2">Nome</label>
                                                <%= f.text_field :name, name: "club_material[name]", class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "Bolas Tamanho 5", value: geral.name %>
                                            </div>

                                            <div class="mb-4">
                                                <label class="block text-sm font-medium text-slate-300 mb-2">Descrição</label>
                                                <%= f.text_field :description, name: "club_material[description]", class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "Bolas de Nike", value: geral.description %>
                                            </div>

                                            <div class="mb-4">
                                                <label class="block text-sm font-medium text-slate-300 mb-2">Quantidade</label>
                                                <%= f.number_field :quantity, name: "club_material[quantity]", step:"1", min: 0, class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "10", value: geral.quantity %>
                                            </div>

                                            <div class="mb-4">
                                                <label class="block text-sm font-medium text-slate-300 mb-2 ">Desporto</label>
                                                <% if @club_profile.has_both_sports? %>
                                                    <%= f.select :sport,
                                                    [["Futebol", "Futebol"], ["Andebol", "Andebol"], ["Geral", "Geral"]],
                                                    {selected: geral.sport , include_blank: false},
                                                    {name: "club_material[sport]", class:"w-full bg-gray-800 rounded-md px-4 py-2 text-white border border-gray-700 focus:ring-2 focus:ring-secondary-500 focus:border-transparent" } %>
                                                <% elsif @club_profile.has_football? %>
                                                    <%= f.select :sport,
                                                    [["Futebol", "Futebol"]],
                                                    {selected: geral.sport, include_blank: false},
                                                    {name: "club_material[sport]", class:"w-full bg-gray-800 rounded-md px-4 py-2 text-white border border-gray-700 focus:ring-2 focus:ring-secondary-500 focus:border-transparent" } %>
                                                <% elsif @club_profile.has_handball? %>
                                                    <%= f.select :sport,
                                                    [["Andebol", "Andebol"]],
                                                    {selected: geral.sport, include_blank: false},
                                                    {name: "club_material[sport]", class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500" } %>
                                                <% end %>
                                            </div>

                                            <div class="flex gap-3 mt-4">
                                                <%= f.submit "Editar", class: "flex-1 bg-yellow-600 hover:bg-yellow-700 text-white font-bold py-2 px-4 rounded-lg transition-colors cursor-pointer" %>
                                                <button type="button" data-modal-target="modal-apagar-geral-<%=geral.id%>" data-modal-toggle="modal-apagar-geral-<%=geral.id%>" class="flex-1 text-center bg-red-600 hover:bg-red-800 text-white font-bold py-2 px-4 rounded-lg transition-colors"> Apagar </button>
                                            </div>
                                        <% end %>


                                </div>
                            </div> 
                            <div id="modal-apagar-geral-<%=geral.id%>" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 modal">
                                <div class="bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4 shadow-2xl border border-gray-700 transform transition-all">
                                    <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-red-900 rounded-full">
                                        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                        </svg>
                                    </div>
                                    <h3 class="text-xl font-semibold text-white text-center mb-2">Confirmar ação</h3>
                                    <p class="text-gray-300 text-center mb-6">Tem a certeza que pretende apagar "<%=geral.name%>"? </p>
                                    <div class="flex gap-3 mt-4">
                                        <button type="button" data-modal-hide="modal-apagar-geral-<%=geral.id%>" class="flex-1 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium">
                                            Cancelar
                                        </button>
                                        <%= button_to "Apagar", club_material_path(geral), 
                                            method: :delete,
                                            class: "flex-1 text-center bg-red-600 hover:bg-red-800 text-white font-bold py-2 px-4 rounded-lg transition-colors",
                                            form: { style: "display: contents" } %>
                                    </div>
                                </div>
                            </div>

                            <div id="modal-apagar-geral-<%=geral.id%>" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 modal">
                                <div class="bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4 shadow-2xl border border-gray-700 transform transition-all">
                                    <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-red-900 rounded-full">
                                        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                        </svg>
                                    </div>
                                    <h3 class="text-xl font-semibold text-white text-center mb-2">Confirmar ação</h3>
                                    <p class="text-gray-300 text-center mb-6">Tem a certeza que pretende apagar "<%=geral.name%>"? </p>
                                    <div class="flex gap-3 mt-4">
                                        <button type="button" data-modal-hide="modal-apagar-geral-<%=geral.id%>" class="flex-1 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium">
                                            Cancelar
                                        </button>
                                        <%= button_to "Apagar", club_material_path(geral), 
                                            method: :delete,
                                            class: "flex-1 text-center bg-red-600 hover:bg-red-800 text-white font-bold py-2 px-4 rounded-lg transition-colors",
                                            form: { style: "display: contents" } %>
                                    </div>
                                </div>
                            </div>

                            <div id="modal-apagar-geral-<%=geral.id%>" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50 modal">
                                <div class="bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4 shadow-2xl border border-gray-700 transform transition-all">
                                    <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-red-900 rounded-full">
                                        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                        </svg>
                                    </div>
                                    <h3 class="text-xl font-semibold text-white text-center mb-2">Confirmar ação</h3>
                                    <p class="text-gray-300 text-center mb-6">Tem a certeza que pretende apagar "<%=geral.name%>"? </p>
                                    <div class="flex gap-3 mt-4">
                                        <button type="button" data-modal-hide="modal-apagar-geral-<%=geral.id%>" class="flex-1 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium">
                                            Cancelar
                                        </button>
                                        <%= button_to "Apagar", club_material_path(geral), 
                                            method: :delete,
                                            class: "flex-1 text-center bg-red-600 hover:bg-red-800 text-white font-bold py-2 px-4 rounded-lg transition-colors",
                                            form: { style: "display: contents" } %>
                                    </div>
                                </div>
                            </div>

                        <% end %>
                    <% else %>
                        <% if params[:query].present? %>
                            <div class="col-span-4 flex flex-col items-center justify-center py-16">
                                <p class="text-xl text-neutral-400">A pesquisa "<%= params[:query] %>" não retornou nenhum material </p>
                            </div>
                        <% else %>
                            <div class="col-span-4 flex flex-col items-center justify-center py-16">
                                <p class="text-xl text-neutral-400">Ainda não tem nenhum material criado</p>
                            </div>
                        <% end %>
                    <% end %>
                <% elsif @selected_sport == 'Futebol' %>
                    <% if @football_materials.any? %>
                        <% @football_materials.each do |football| %>
                            <div data-modal-target="modal-edit-material-football-<%=football.id%>" data-modal-toggle="modal-edit-material-football-<%=football.id%>" class="bg-gray-800 border border-gray-700 rounded-xl overflow-hidden transition-all hover:scale-[1.01] hover:shadow-lg hover:shadow-primary/10 clickable">
                                <% if football.image.attached? %>
                                    <div class="relative h-40 bg-gray-900 flex items-center justify-center">
                                        <%= image_tag url_for(football.image), class: "w-full h-full object-cover" %>
                                    </div>
                                <% else %>
                                    <div class="relative h-40 bg-gray-900 flex items-center justify-center">
                                        <i data-feather="box" class="w-16 h-16 text-gray-300"></i>
                                    </div>
                                <% end %>
                                <div class="p-4">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <h3 class="font-bold text-lg"> <%= football.name %> </h3>
                                            <p class="text-gray-400 text-sm"> <%= football.description %> </p>
                                        </div>
                                        <div>
                                            <p class="text-md text-gray-400">Qtd.</p>
                                            <p class="font-medium text-center"> <%= football.quantity %> </p>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div id="modal-edit-material-football-<%=football.id%>" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
                                <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                                    <div class="flex justify-between items-center mb-6">
                                        <h2 class="text-2xl font-bold text-yellow-400">Editar Material</h2>
                                        <button data-modal-hide="modal-edit-material-geral-<%=football.id%>" class="text-slate-400 hover:text-white">
                                            <i data-feather="x"></i>
                                        </button>
                                    </div>

                                        <%= form_with url: club_material_path(football), method: :patch, multipart: true,  data: { turbo: false } do |f| %>

                                            <div class="mb-4">
                                                <label class="block text-sm font-medium text-slate-300 mb-2">Nome</label>
                                                <%= f.text_field :name, name: "club_material[name]", class:"w-full bg-slate-900 border border-slate-700 rounded-lg p-2 text-white focus:outline-none focus:ring-2 focus:ring-green-500", placeholder: "Bolas Tamanho 5", value: football.name %>
                                            </div>

