        <script>
            function toggleLockerRoomTimes(selectElement, suffix) {
                const container = document.getElementById('locker-room-times-' + suffix);
                if (selectElement.value) {
                    container.classList.remove('hidden');
                } else {
                    container.classList.add('hidden');
                }
            }
