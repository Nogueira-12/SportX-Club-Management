                                        <div class="text-xs text-blue-100 truncate"><%= training.pitch_zone %></div>
                                        <% end %>
                                        <% if training.club_locker_room.present? %>
                                        <div class="text-xs text-rose-300 truncate"><%= training.club_locker_room.name %></div>
