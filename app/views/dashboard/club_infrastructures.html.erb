                            <label class="block text-sm font-medium text-gray-400 mb-1">Foto do Balneário</label>

                            <div class="relative w-full h-40 rounded-lg overflow-hidden shadow-lg">
                                <%= image_tag "placeholder.jpg",
                                    id: "locker-room-picture-preview",
                                    alt: "Pré-visualização do banner",
                                    class: "w-full h-full object-cover cursor-pointer" %>

                                <%= form.file_field :locker_room_picture,
                                    id: "locker-room-picture",
                                    class: "file-upload-input sr-only",
                                    accept: "image/*" %>
                                
                                <button type="button" id="remove-locker-room-picture-btn" class="hidden absolute inset-0 bg-red-500 bg-opacity-0 hover:bg-opacity-90 text-white font-medium transition-all duration-300 flex items-center justify-center opacity-0 hover:opacity-100">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                </button>
                            </div>

                            <br>
                            
                            <label class="block text-sm font-medium text-gray-400 mb-1 required-label">Nome do Balneário</label>
                            
                            <%= form.text_field :name, class: "w-full bg-gray-800 rounded-md px-4 py-2 text-white border border-gray-700 focus:ring-2 focus:ring-secondary-500 focus:border-transparent" ,placeholder: "Ex: Balneário 5", required: true, autofocus: true %>

                            <% if @selected_sport == 'football' %>
                                <%= form.hidden_field :sport_id, value: 2 %>
                            <% elsif @selected_sport == 'handball' %>
                                <%= form.hidden_field :sport_id, value: 3 %>
                            <% end %>
                            <br> <br>
                            <button type="submit" class="w-full inline-flex items-center justify-center gap-2 px-4 py-2 rounded-md text-white font-medium shadow-md transition-transform duration-150 transform hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-emerald-500 bg-gradient-to-r from-emerald-900 to-emerald-800 hover:from-emerald-800 hover:to-emerald-500">
                            <i data-feather="check" class="w-4 h-4"></i>
                            <span>Criar Balneário</span>
                            </button>
                        <% end %> 

                        </ul>
                    </div>
                </div>
            </div>
        </div>


