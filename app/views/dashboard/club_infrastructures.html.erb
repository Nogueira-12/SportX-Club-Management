                                    <%= f.submit "Criar Treino", class: "flex-1 px-4 py-2 bg-green-600 hover:bg-green-700 text-white rounded-lg clickable" %>
                                    </div>
                                <% end %>
                                </div>
                            </div>
                            <% end %>

                        <% @trainings_by_date.values.flatten.uniq { |t| t.id }.each do |training| %>
