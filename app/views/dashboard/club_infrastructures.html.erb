        <!-- Script ver e remover foto do ct -->

        <script>
            document.addEventListener('DOMContentLoaded', function() {
                
                const CtPicInput = document.getElementById('ct-picture');
                const CtPicPreview = document.getElementById('ct-picture-preview');
                const RemoveCtPicBtn = document.getElementById('remove-ct-picture-btn');
                const originalBannerSrc = CtPicPreview ? CtPicPreview.src : '';

                if (CtPicInput && CtPicPreview) {
                CtPicInput.addEventListener('change', (e) => {
                    const file = e.target.files[0];
                    if (file && file.type.startsWith('image/')) {
                    const reader = new FileReader();
                    reader.onload = (ev) => {
                        CtPicPreview.src = ev.target.result;
                        RemoveCtPicBtn.classList.remove('hidden');
                    };
                    reader.readAsDataURL(file);
                    }
                });

                CtPicPreview.addEventListener('click', () => {
                    CtPicInput.click();
                });

                if (RemoveCtPicBtn) {
                    RemoveCtPicBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    CtPicInput.value = '';
                    CtPicPreview.src = originalBannerSrc;
                    RemoveCtPicBtn.classList.add('hidden');
                    });
                }
                }
            });
        </script>

