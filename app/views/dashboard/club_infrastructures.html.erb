                                    <div>
                                        <label class="block text-sm font-medium text-gray-400 mb-2">Tempo depois do treino (minutos)</label>
                                        <%= f.select :locker_room_time_after, [[0, 0],  [30, 30], [60, 60]], { selected: 0 }, class: "w-full bg-gray-600 text-white rounded px-3 py-2" %>
                                    </div>
                                    </div>
                                    
                                    <div class="mb-4">
                                    <label class="block text-sm font-medium text-gray-400 mb-2">Duração</label>
                                    <%= f.select :duration_minutes, [["30 min", 30], ["1h", 60], ["1h30", 90], ["2h", 120]], {}, class: "w-full bg-gray-700 text-white rounded px-3 py-2" %>
                                    </div>

                                    <div class="mb-4">
                                    <label class="block text-sm font-medium text-gray-400 mb-2">Zona do Campo</label>
                                    <%= f.select :pitch_zone, @available_zones, { include_blank: false }, class: "w-full bg-gray-700 text-white rounded px-3 py-2" %>
                                    </div>

                                    <div class="mb-4">
                                    <label class="flex items-center text-gray-400">
                                        <%= f.check_box :recurring, class: "mr-2" %>
