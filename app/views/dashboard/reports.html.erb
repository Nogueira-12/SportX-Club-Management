<body class="min-h-screen flex text-white bg-gray-900">
<!---------------------------------------------------- NOME E LOGO DO CLUBE ---------------------------------------------------->
    <div class="w-64 bg-slate-800 shadow-xl min-h-screen flex flex-col border-r border-slate-700">
    <!-- Logo e nome do clube -->
        <div class="p-6 border-b border-slate-700">
            <div class="flex items-center justify-center mb-3">
                
                <% if current_user.admin_profile.profile_picture.attached? %>
                    <%= image_tag url_for(current_user.admin_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-20 h-20 rounded-full border-1" %>
                <% end %>

                
            </div>
            <h1 class="text-lg font-bold text-center text-white">
                <%= current_user.admin_profile.name %>
            </h1>
        </div>
<!---------------------------------------------------- OPÇÕES DO SIDEBAR ---------------------------------------------------->
        <nav class="flex-1 p-4 space-y-2">
            
            <%= link_to admin_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-blue-400 rounded-xl border-l-4 border-transparent hover:border-blue-500 transition-all duration-300">
                <i data-feather="home" class="sidebar-icon text-blue-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Dashboard</span>
            </div>
            <% end %>

            <% if current_user.admin_profile.super? %>
              <%= link_to list_admins_dashboard_path do %>
              <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-purple-400 rounded-xl border-l-4 border-transparent hover:border-purple-500 transition-all duration-300">
                  <i data-feather="user" class="sidebar-icon text-purple-400 w-5 h-5 mr-3"></i>
                  <span class="font-medium">Admins</span>
              </div>
              <% end %>
            <% end %>

            <%= link_to club_verification_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-green-400 rounded-xl border-l-4 border-transparent hover:border-green-500 transition-all duration-300">
                <i data-feather="users" class="sidebar-icon text-green-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Verificação de Clubes</span>
            </div>
            <% end %>


            <%= link_to reports_dashboard_path do %>
            <div  class="sidebar-item flex items-center px-4 py-3 text-slate-300 bg-slate-700 text-yellow-400 rounded-xl border-l-4 border-transparent border-yellow-500 transition-all duration-300">
                <i data-feather="alert-triangle" class="sidebar-icon text-yellow-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Reports</span>
            </div>
            <% end %>

            <%= link_to bans_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-red-400 rounded-xl border-l-4 border-transparent hover:border-red-500 transition-all duration-300">
                <i data-feather="slash" class="sidebar-icon text-red-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Bans</span>
            </div>
            <% end %>

            <%= link_to root_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-gray-400 rounded-xl border-l-4 border-transparent hover:border-gray-400 transition-all duration-300">
                <i data-feather="arrow-left" class="sidebar-icon text-gray-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Página Inicial</span>
            </div>
            <% end %>
        </nav>


        <div class="p-4 border-t border-slate-700">
            <div class="flex items-center space-x-3">
                <% if current_user.admin_profile.profile_picture.attached? %>
                    <%= image_tag url_for(current_user.admin_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% end %>
                <div class="flex-1">
                        <p class="text-sm font-medium text-white"> <%= current_user.admin_profile.name %> </p>
                </div>
                <%= button_to destroy_user_session_path, method: :delete do %>
                    <i data-feather="log-out" class="text-slate-400 hover:text-red-400 cursor-pointer transition-colors"></i>
                <% end %>
            </div>
        </div>
</div>
<!-------------------------------------------------------------------------------- MAIN ------------------------------------------------------------------------->
    <div class="flex-1 p-8">

            <div class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-yellow-500 slide-in">Reports</h1>
                    <p class="text-slate-400 mt-1">Veja e resolva todos os Reports que foram feitos contra perfis na plataforma</p> 
                </div>
            </div>
            <br>

            <!---------------------------------------------------- PESQUISAS ---------------------------------------------------->
            <div class="flex items-center mb-6 gap-x-4">
                <%= form_with url: reports_dashboard_path, method: :get, local: true, id: "search-form" do %>
                    <%= hidden_field_tag :type, @type %>
                    <div class="relative w-80">
                        <i data-feather="search" class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 w-4 h-4 pointer-events-none z-10"></i>
                        <%= text_field_tag :query, params[:query], placeholder: "Pesquisar Perfil de Reportado", class: "bg-gray-800 border border-gray-700 rounded-lg pl-10 pr-10 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white", oninput: "clearTimeout(window.searchTimeout); window.searchTimeout = setTimeout(() => this.form.requestSubmit(), 1000); toggleClearButton(this)", id: "search-input" %>
                        <button type="button" id="clear-search" onclick="clearSearch()" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-white transition <%= 'hidden' unless params[:query].present? %>">
                            <i data-feather="x" class="w-4 h-4 text-red-400"></i>
                        </button>
                    </div>
                <% end %>

                <%= link_to reports_dashboard_path(type: "Pendentes") do %>
                    <button class="px-6 py-2 rounded-full border transition-all duration-200 <%= @type == "Pendentes" ? 'bg-blue-600 border-blue-500 text-white' : 'bg-gray-800 border-gray-600 text-gray-300 hover:border-blue-500 hover:text-blue-400 hover:bg-blue-500/10' %>">Pendentes</button>
                <% end %>
                <%= link_to reports_dashboard_path(type: "Resolvidos") do %>
                    <button class="px-6 py-2 rounded-full border transition-all duration-200 <%= @type == "Resolvidos" ? 'bg-blue-600 border-blue-500 text-white' : 'bg-gray-800 border-gray-600 text-gray-300 hover:border-blue-500 hover:text-blue-400 hover:bg-blue-500/10' %>">Resolvidos</button>
                <% end %>

            </div>

            
<!-------------------------------------------------------------------------------- REPORTS ------------------------------------------------------------------------->

            <div class="mb-12">
                <% if !params[:query].present? or (params[:query].present? and @reports_count != 0) %>
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-xl font-bold text-yellow-400 flex items-center space-x-2">
                            <i data-feather="alert-triangle" class="w-6 h-6"></i>
                            <span>Reports ( <%= @reports_count %> )</span>
                        </h3>

                    </div>
                <% end %>

                <% if params[:query].present? and @reports_count == 0 %>
                    <br>
                    <div class="flex justify-center items-center mb-8">
                        <div class="flex flex-col items-start">
                            <h1 class="text-2xl text-neutral-400 slide-in mx-auto">A pesquisa "<%= params[:query] %>" não retornou nenhum perfil reportado! </h1>
                        </div>
                    </div>
                <% end %>

                <% if @reports&.any? %>
                    <div class="grid grid-cols-4 justify-center gap-6">
                    <% @reports.each do |report| %>
                        <div data-modal-target="report-<%=report.id%>" data-modal-toggle="report-<%= report.id %>" class=" clickable bg-gray-800 border-l-4 border-yellow-500 rounded-xl overflow-hidden transition-all hover:scale-[1.01] hover:shadow-lg relative">
                                <div class="p-4">
                                    <div class="flex items-center justify-between gap-3 mb-3">
                                        <div class="flex items-center gap-3 overflow-hidden">
                                            <div class="w-10 h-10 rounded-full flex-shrink-0 overflow-hidden">
                                                <% if report.user.club? %>
                                                    <% reported_profile = report.user.club_profile %>
                                                <% elsif report.user.player? %>
                                                    <% reported_profile = report.user.player_profile %>
                                                <% elsif report.user.coach? %>
                                                    <% reported_profile = report.user.coach_profile %>
                                                <% elsif report.user.user? %>
                                                    <% reported_profile = report.user.user_profile %>
                                                <% elsif report.user.board? %>
                                                    <% reported_profile = report.user.board_profile %>
                                                <% end %>
                                                <% if reported_profile.profile_picture.attached? %>
                                                    <%= image_tag url_for(reported_profile.profile_picture), class: "w-full h-full object-cover" %>
                                                <% else %>
                                                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                                <% end %>
                                            </div>
                                            <p class="font-bold text-white text-sm truncate"><%= reported_profile.name %></p>
                                        </div>
                                        <% if report.pending? %>
                                            <span class="text-xs font-medium px-2 py-1 rounded-full bg-yellow-900 text-yellow-300 flex-shrink-0">Pendente</span>
                                        <% else %>
                                            <span class="text-xs font-medium px-2 py-1 rounded-full bg-green-900 text-green-300 flex-shrink-0">Resolvido</span>
                                        <% end %>
                                    </div>


                                <hr class="border-slate-700 mb-3">

                                <div class="mb-2">
                                    <p class="text-xs text-slate-400">Reportado por:</p>
                                    <% reporter = User.find_by(id: report.reported_by) %>
                                    <% if reporter.club? %>
                                        <% reporter_profile = reporter.club_profile %>
                                    <% elsif reporter.player? %>
                                        <% reporter_profile = reporter.player_profile %>
                                    <% elsif reporter.coach? %>
                                        <% reporter_profile = reporter.coach_profile %>
                                    <% elsif reporter.user? %>
                                        <% reporter_profile = reporter.user_profile %>
                                    <% elsif reporter.board? %>
                                        <% reporter_profile = reporter.board_profile %>
                                    <% elsif reporter.admin? %>
                                        <% reporter_profile = reporter.admin_profile %>
                                    <% end %>
                                    
                                    
                                    <div class="flex items-center gap-2 mt-1">
                                        <div class="w-7 h-7 rounded-full flex-shrink-0 overflow-hidden">
                                            <% if reporter_profile.profile_picture.attached? %>
                                                <%= image_tag url_for(reporter_profile.profile_picture), class: "w-full h-full object-cover" %>
                                            <% else %>
                                                <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                            <% end %>
                                        </div>
                                        <p class="font-bold text-white text-sm truncate"><%= reporter_profile.name %></p>
                                    </div>
                                </div>

                                <div>
                                    <p class="text-xs text-slate-400">Criado a:</p>
                                    <p class="text-sm font-medium text-white"> <%= l(report.created_at, format: :long, locale: :pt) %> </p>
                                </div>

                                <% if report.resolved? %>
                                    <div>
                                        <p class="text-xs text-slate-400">Resolvido a:</p>
                                        <p class="text-sm font-medium text-white"> <%= l(report.updated_at, format: :long, locale: :pt) %> </p>
                                    </div>
                                <% end %>

                                </div>

                            </div>

                            <div id="report-<%=report.id%>" class="fixed inset-0 bg-black bg-opacity-50 hidden items-center justify-center z-50">
                                <div class="bg-slate-800 rounded-lg shadow-xl p-8 w-full max-w-md border border-slate-700">
                                    <div class="flex justify-between items-center mb-6">
                                        <h2 class="text-2xl font-bold text-yellow-400">Report</h2>
                                        <button data-modal-hide="report-<%=report.id%>" class="text-slate-400 hover:text-white">
                                            <i data-feather="x"></i>
                                        </button>
                                    </div>
                                        <div class="flex gap-4 mb-6">
                                            <%# ---- REPORTADO ---- %>
                                            <div class="flex-1">
                                                <p class="text-xs text-slate-400 mb-2">Report Contra:</p>
                                                <% 
                                                    profile_path_reported = case 
                                                        when report.user.club?   then club_profile_path(reported_profile)
                                                        when report.user.player? then player_profile_path(reported_profile)
                                                        when report.user.coach?  then coach_profile_path(reported_profile)
                                                        when report.user.board?  then board_profile_path(reported_profile)
                                                        when report.user.user?   then user_profile_path(reported_profile)
                                                    end
                                                %>
                                                <%= link_to profile_path_reported, class: "flex items-center gap-2 group" do %>
                                                    <div class="w-8 h-8 rounded-full flex-shrink-0 overflow-hidden">
                                                        <% if reported_profile.profile_picture.attached? %>
                                                            <%= image_tag url_for(reported_profile.profile_picture), class: "w-full h-full object-cover" %>
                                                        <% else %>
                                                            <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                                        <% end %>
                                                    </div>
                                                    <span class="text-sm font-bold text-white truncate group-hover:underline transition-all"><%= reported_profile.name %></span>
                                                <% end %>
                                            </div>

                                            <%# ---- DIVISOR VERTICAL ---- %>
                                            <div class="w-px bg-slate-600 self-stretch"></div>

                                            <%# ---- REPORTER ---- %>
                                            <div class="flex-1">
                                                <p class="text-xs text-slate-400 mb-2">Report feito por:</p>
                                                <%
                                                    profile_path_reporter = case
                                                        when reporter.club?   then club_profile_path(reporter_profile)
                                                        when reporter.player? then player_profile_path(reporter_profile)
                                                        when reporter.coach?  then coach_profile_path(reporter_profile)
                                                        when reporter.board?  then board_profile_path(reporter_profile)
                                                        when reporter.user?   then user_profile_path(reporter_profile)
                                                        when reporter.admin?  then admin_profile_path(reporter_profile)
                                                    end
                                                %>
                                                <%= link_to profile_path_reporter, class: "flex items-center gap-2 group" do %>
                                                    <div class="w-8 h-8 rounded-full flex-shrink-0 overflow-hidden">
                                                        <% if reporter_profile.profile_picture.attached? %>
                                                            <%= image_tag url_for(reporter_profile.profile_picture), class: "w-full h-full object-cover" %>
                                                        <% else %>
                                                            <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                                        <% end %>
                                                    </div>
                                                    <span class="text-sm font-bold text-white truncate group-hover:underline transition-all"><%= reporter_profile.name %></span>
                                                <% end %>
                                            </div>
                                        </div>
                                            <div class="mb-4">
                                                <p class="text-xs text-slate-400 mb-1">Motivo do Report:</p>
                                                <p class="text-sm text-white bg-slate-700 rounded-lg p-3"><%= report.content %></p>
                                            </div>

                                            <% if report.pending? %>
                                                <%= form_with url: resolve_report_dashboard_path(report), method: :patch, local: true, id: "form-report-#{report.id}" do |f| %>
                                                <div class="mb-4">
                                                    <label class="text-xs text-slate-400 mb-1 block">Observações <span class="text-red-400">*</span></label>
                                                    <%= f.text_area :admin_observations,
                                                        id: "obs-#{report.id}",
                                                        placeholder: "Escreve as observações sobre este report...",
                                                        required: true,
                                                        class: "w-full bg-slate-700 border border-slate-600 rounded-lg p-3 text-sm text-white resize-none focus:outline-none focus:ring-2 focus:ring-yellow-500",
                                                        rows: 3,
                                                        oninput: "toggleResolveBtn('#{report.id}', this.value)" %>
                                                </div>

                                                <button type="submit"
                                                    id="btn-resolve-<%= report.id %>"
                                                    disabled
                                                    class="w-full bg-green-600 hover:bg-green-700 disabled:opacity-40 disabled:cursor-not-allowed text-white font-bold py-2 px-4 rounded-lg transition-colors">
                                                    Resolver Report
                                                </button>
                                                <% end %>
                                            <% else %>
                                                <label class="block text-sm font-medium text-slate-300 mb-2">Report resolvido por:</label>
                                                    <% user = User.find_by(id: report.resolved_by) %>
                                                    <% admin = user.admin_profile %>
                                                    <%= link_to admin_profile_path(admin), class: "block mb-6 rounded-xl overflow-hidden border border-slate-600 hover:border-slate-400 transition-colors" do %>

                                                        <div class="relative h-24 w-full">
                                                            <% if admin.banner_picture.attached? %>
                                                                <%= image_tag url_for(admin.banner_picture), class: "w-full h-full object-cover" %>
                                                            <% else %>
                                                                <%= image_tag "default_banner.jpg", class: "w-full h-full object-cover" %>
                                                            <% end %>
                                                        </div>

                                                        <div class="bg-slate-700 px-4 pb-4 pt-10 relative">
                                                            <div class="absolute -top-8 left-4 w-16 h-16 rounded-full overflow-hidden border-4 border-slate-700 shadow-lg">
                                                                <% if admin.profile_picture.attached? %>
                                                                    <%= image_tag url_for(admin.profile_picture), class: "w-full h-full object-cover" %>
                                                                <% else %>
                                                                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                                                <% end %>
                                                            </div>

                                                            <div class="flex items-center justify-between">
                                                                <span class="text-lg font-bold text-white"><%= admin.name %></span>
                                                            </div>
                                                        </div>
                                                    <% end %>
                                                <div class="mb-4">
                                                    <p class="text-xs text-slate-400 mb-1">Observações:</p>
                                                    <p class="text-sm text-white bg-slate-700 rounded-lg p-3"><%= report.admin_observations %></p>
                                                </div>
                                                <button class="w-full bg-yellow-600 hover:bg-yellow-700 disabled:opacity-40 text-white font-bold py-2 px-4 rounded-lg transition-colors" data-modal-toggle="unresolve-report-<%=report.id%>" data-modal-target="unresolve-report-<%=report.id%>">
                                                    Colocar como pendente
                                                </button>
                                            <% end %>
                                </div>
                            </div> 
                            
                            <div id="unresolve-report-<%=report.id%>" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50">
                                <div class="bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4 shadow-2xl border border-gray-700 transform transition-all">
                                    <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-red-900 rounded-full">
                                        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                        </svg>
                                    </div>
                                    <h3 class="text-xl font-semibold text-white text-center mb-2">Confirmar ação</h3>
                                    <p class="text-gray-300 text-center mb-6"> Tem a certeza que pretende voltar a colocar este report como pendente?  </p>
                                    <div class="flex gap-3">
                                        <button data-modal-hide="unresolve-report-<%=report.id%>" class="flex-1 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium">
                                            Cancelar
                                        </button>
                                        <%= button_to "Colocar como pendente", unresolve_report_dashboard_path(report), method: :patch, class: "w-full bg-yellow-600 hover:bg-yellow-700 disabled:opacity-40 text-white font-bold py-2 px-4 rounded-lg transition-colors" %>
                                    </div>
                                </div>
                            </div>


                    <% end %>
                <% end %>

                </div> 

                <% if @reports.total_pages > 1 %>
                <div class="mt-8 flex justify-end">
                    <div class="flex flex-col items-end gap-3">               

                    <div class="flex items-center gap-2">
                        <% if @reports.prev_page %>
                        <%= link_to reports_dashboard_path(type: @type, query: params[:query], reports_page: @reports.prev_page), class: "flex items-center gap-2 px-4 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white rounded-lg border border-gray-700 transition-all duration-200 font-medium" do %>
                            <i data-feather="chevron-left" class="w-4 h-4"></i>
                            <span>Anterior</span>
                        <% end %>
                        <% else %>
                        <div class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/50 text-gray-600 rounded-lg border border-gray-700/50 cursor-not-allowed font-medium">
                            <i data-feather="chevron-left" class="w-4 h-4"></i>
                            <span>Anterior</span>
                        </div>
                        <% end %>

                        <div class="flex items-center gap-1">
                        <% (1..@reports.total_pages).each do |page| %>
                            <% if page == @reports.current_page %>
                            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-yellow-600 text-white font-bold border-2 border-yellow-500 shadow-lg">
                                <%= page %>
                            </div>
                            <% else %>
                            <%= link_to page, reports_dashboard_path(type: @type, query: params[:query], reports_page: page), class: "w-10 h-10 flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white border border-gray-700 transition-all duration-200 font-medium" %>
                            <% end %>
                        <% end %>
                        </div>

                        <% if @reports.next_page %>
                        <%= link_to reports_dashboard_path(type: @type, query: params[:query], reports_page: @reports.next_page), class: "flex items-center gap-2 px-4 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white rounded-lg border border-gray-700 transition-all duration-200 font-medium" do %>
                            <span>Seguinte</span>
                            <i data-feather="chevron-right" class="w-4 h-4"></i>
                        <% end %>
                        <% else %>
                        <div class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/50 text-gray-600 rounded-lg border border-gray-700/50 cursor-not-allowed font-medium">
                            <span>Seguinte</span>
                            <i data-feather="chevron-right" class="w-4 h-4"></i>
                        </div>
                        <% end %>
                    </div>
                    </div>
                </div>

                <% elsif !@reports&.any? and !params[:query].present? %>
                    <div class="flex justify-center items-center mb-8">
                        <div class="flex flex-col items-start">
                            <h1 class="text-2xl text-neutral-400 slide-in mx-auto">Ainda não existe nenhum report!</h1>
                        </div>
                    </div>
                <% end %>
                
            </div>
            
    </div>

<script>
    feather.replace()
</script>

<!-- Configuração da cor principal e secundária do tailwind -->

<script>
    tailwind.config = {
        darkMode: 'class',
        theme: {
            extend: {
                colors: {
                    primary: {
                        500: '#6366f1',
                    },
                    secondary: {
                        500: '#8b5cf6',
                    }
                }
            }
        }
    }
</script>

<script>
    tailwind.config = {
        darkMode: 'class',
        theme: {
            extend: {
                colors: {
                    primary: {
                        50: '#f0f9ff',
                        100: '#e0f2fe',
                        200: '#bae6fd',
                        300: '#7dd3fc',
                        400: '#38bdf8',
                        500: '#0ea5e9',
                        600: '#0284c7',
                        700: '#0369a1',
                        800: '#075985',
                        900: '#0c4a6e',
                    },
                    secondary: {
                        50: '#fdf4ff',
                        100: '#fae8ff',
                        200: '#f5d0fe',
                        300: '#f0abfc',
                        400: '#e879f9',
                        500: '#d946ef',
                        600: '#c026d3',
                        700: '#a21caf',
                        800: '#86198f',
                        900: '#701a75',
                    }
                }
            }
        }
    }
</script>

<script>
    function toggleClearButton(input) {
        const clearBtn = document.getElementById('clear-search');
        if (input.value.length > 0) {
            clearBtn.classList.remove('hidden');
        } else {
            clearBtn.classList.add('hidden');
        }
    }

    function clearSearch() {
        const input = document.getElementById('search-input');
        input.value = '';
        document.getElementById('clear-search').classList.add('hidden');
        document.getElementById('search-form').requestSubmit();
    }

    
</script>

<script>
  function toggleResolveBtn(reportId, value) {
    const btn = document.getElementById('btn-resolve-' + reportId);
    btn.disabled = value.trim().length === 0;
}
</script>