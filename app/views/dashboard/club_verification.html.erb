<script>
    function toggleClearButton(input) {
        const clearBtn = document.getElementById('clear-search');
        if (input.value.length > 0) {
            clearBtn.classList.remove('hidden');
        } else {
            clearBtn.classList.add('hidden');
        }
    }

    function clearSearch() {
        const input = document.getElementById('search-input');
        input.value = '';
        document.getElementById('clear-search').classList.add('hidden');
        document.getElementById('search-form').requestSubmit();
    }

    // Declarações primeiro — só depois de declarar é que podes usar estas variáveis
    const imageModal     = document.getElementById('image-modal');
    const modalImage     = document.getElementById('modal-image');
    const closeImageBtn  = document.getElementById('close-image-modal');
    const pdfModal       = document.getElementById('pdf-modal');
    const modalPdf       = document.getElementById('modal-pdf');
    const closePdfBtn    = document.getElementById('close-pdf-modal');

    const pdfModalContainer = document.getElementById('pdf-modal-container');
    const zoomPdfBtn        = document.getElementById('zoom-pdf-modal');
    let isPdfZoomed = false;

    zoomPdfBtn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (isPdfZoomed) {
            pdfModalContainer.style.width  = '800px';
            pdfModalContainer.style.height = '85vh';
            isPdfZoomed = false;
        } else {
            pdfModalContainer.style.width  = '95vw';
            pdfModalContainer.style.height = '95vh';
            isPdfZoomed = true;
        }
    });

    const closePdfModal = () => {
        pdfModal.classList.add('hidden');
        pdfModal.classList.remove('flex');
        document.body.style.overflow = '';
        modalPdf.src = '';
        isPdfZoomed = false;
        pdfModalContainer.style.width  = '800px';
        pdfModalContainer.style.height = '85vh';
    };

    let isZoomed = false;

    // Fecha o modal de imagem e reseta o zoom
    const closeImageModal = () => {
        imageModal.classList.add('hidden');
        imageModal.classList.remove('flex');
        document.body.style.overflow = '';
        // Reseta o zoom para a próxima vez que abrir
        isZoomed = false;
        modalImage.style.width  = '500px';
        modalImage.style.height = '350px';
        modalImage.classList.replace('cursor-zoom-out', 'cursor-zoom-in');
    };


    // Zoom na imagem ao clicar
    modalImage.addEventListener('click', (e) => {
        e.stopPropagation(); // impede que o clique chegue ao fundo escuro e feche o modal
        if (isZoomed) {
            modalImage.style.width  = '500px';
            modalImage.style.height = '350px';
            modalImage.classList.replace('cursor-zoom-out', 'cursor-zoom-in');
            isZoomed = false;
        } else {
            modalImage.style.width  = '90vw';
            modalImage.style.height = '80vh';
            modalImage.classList.replace('cursor-zoom-in', 'cursor-zoom-out');
            isZoomed = true;
        }
    });

    // Botões de fechar
    closeImageBtn.addEventListener('click', closeImageModal);
    closePdfBtn.addEventListener('click', closePdfModal);

    // Fechar ao clicar no fundo escuro
    imageModal.addEventListener('click', (e) => { if (e.target === imageModal) closeImageModal(); });
    pdfModal.addEventListener('click',   (e) => { if (e.target === pdfModal)   closePdfModal();   });

    // Listener em cada contentor de documento
    document.querySelectorAll('[id^="profile-pic-container-"]').forEach(container => {
        const clubId  = container.id.replace('profile-pic-container-', '');
        const docType = container.dataset.docType; // "pdf" ou "image", definido no HTML

        container.addEventListener('click', () => {
            const el = document.getElementById('profile-pic-img-' + clubId);
            if (!el) return;

            if (docType === 'pdf') {
                // Abre o modal de PDF com o src do iframe
                modalPdf.src = el.dataset.pdfUrl;
                pdfModal.classList.remove('hidden');
                pdfModal.classList.add('flex');
                document.body.style.overflow = 'hidden';
            } else {
                // Abre o modal de imagem
                modalImage.src = el.src;
                imageModal.classList.remove('hidden');
                imageModal.classList.add('flex');
                document.body.style.overflow = 'hidden';
            }
        });
    });

    feather.replace();
</script>

