<body class="min-h-screen flex text-white bg-gray-900">
<!---------------------------------------------------- NOME E LOGO DO CLUBE ---------------------------------------------------->
    <div class="w-64 bg-slate-800 shadow-xl min-h-screen flex flex-col border-r border-slate-700">
    <!-- Logo e nome do clube -->
        <div class="p-6 border-b border-slate-700">
            <div class="flex items-center justify-center mb-3">
                
                <% if current_user.admin_profile.profile_picture.attached? %>
                    <%= image_tag url_for(current_user.admin_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-20 h-20 rounded-full border-1" %>
                <% end %>

                
            </div>
            <h1 class="text-lg font-bold text-center text-white">
                <%= current_user.admin_profile.name %>
            </h1>
        </div>
<!---------------------------------------------------- OPÇÕES DO SIDEBAR ---------------------------------------------------->
        <nav class="flex-1 p-4 space-y-2">
            
            <%= link_to admin_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 bg-slate-700 text-blue-400 rounded-xl border-l-4 border-blue-500 transition-all duration-300">
                <i data-feather="home" class="sidebar-icon text-blue-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Dashboard</span>
            </div>
            <% end %>

            <% if current_user.admin_profile.super? %>
              <%= link_to list_admins_dashboard_path do %>
              <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-purple-400 rounded-xl border-l-4 border-transparent hover:border-purple-500 transition-all duration-300">
                  <i data-feather="user" class="sidebar-icon text-purple-400 w-5 h-5 mr-3"></i>
                  <span class="font-medium">Admins</span>
              </div>
              <% end %>
            <% end %>

            <%= link_to club_verification_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-green-400 rounded-xl border-l-4 border-transparent hover:border-green-500 transition-all duration-300">
                <i data-feather="users" class="sidebar-icon text-green-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Verificação de Clubes</span>
            </div>
            <% end %>


            <%= link_to reports_dashboard_path do %>
            <div  class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-yellow-400 rounded-xl border-l-4 border-transparent hover:border-yellow-500 transition-all duration-300">
                <i data-feather="alert-triangle" class="sidebar-icon text-yellow-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Reports</span>
            </div>
            <% end %>

            <%= link_to bans_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-red-400 rounded-xl border-l-4 border-transparent hover:border-red-500 transition-all duration-300">
                <i data-feather="slash" class="sidebar-icon text-red-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Bans</span>
            </div>
            <% end %>

            <%= link_to root_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-gray-400 rounded-xl border-l-4 border-transparent hover:border-gray-400 transition-all duration-300">
                <i data-feather="arrow-left" class="sidebar-icon text-gray-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Página Inicial</span>
            </div>
            <% end %>
        </nav>


        <div class="p-4 border-t border-slate-700">
            <div class="flex items-center space-x-3">
                <% if current_user.admin_profile.profile_picture.attached? %>
                    <%= image_tag url_for(current_user.admin_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% end %>
                <div class="flex-1">
                        <p class="text-sm font-medium text-white"> <%= current_user.admin_profile.name %> </p>
                </div>
                <%= button_to destroy_user_session_path, method: :delete do %>
                    <i data-feather="log-out" class="text-slate-400 hover:text-red-400 cursor-pointer transition-colors"></i>
                <% end %>
            </div>
        </div>
</div>
<!---------------------------------------------------- MAIN CONTENT ---------------------------------------------------->
<div class="flex-1 overflow-auto">
  <div class="p-8">

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-blue-400">Dashboard</h1>
      <p class="text-slate-400 mt-1">Visão geral de toda a plataforma</p>
    </div>

    <!-- Cards de topo -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

      <!-- Utilizadores -->
      <div class="stat-card rounded-xl shadow-lg p-6 border-l-4 border-blue-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-slate-400">Total de Utilizadores</p>
            <p class="text-2xl font-bold text-white"><%= @total_users %></p>
            <p class="text-xs text-green-400 mt-1">+<%= @novos_users_semana %> esta semana</p>
          </div>
          <div class="w-12 h-12 bg-blue-900/30 rounded-lg flex items-center justify-center">
            <i data-feather="users" class="text-blue-400"></i>
          </div>
        </div>
      </div>

      <!-- Posts -->
      <div class="stat-card rounded-xl shadow-lg p-6 border-l-4 border-yellow-500">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-slate-400">Total de Posts</p>
            <p class="text-2xl font-bold text-white"><%= @total_posts %></p>
            <p class="text-xs text-green-400 mt-1">+<%= @novos_posts_semana %> esta semana</p>
          </div>
          <div class="w-12 h-12 bg-yellow-900/30 rounded-lg flex items-center justify-center">
            <i data-feather="file-text" class="text-yellow-400"></i>
          </div>
        </div>
      </div>

      <!-- Clubes Pendentes -->
      <div class="stat-card rounded-xl shadow-lg p-6 border-l-4 <%= @clubes_pendentes > 0 ? 'border-red-500' : 'border-slate-500' %>">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-slate-400">Clubes Pendentes</p>
            <p class="text-2xl font-bold <%= @clubes_pendentes > 0 ? 'text-red-400' : 'text-white' %>"><%= @clubes_pendentes %></p>
            <p class="text-xs <%= @novos_pendentes_semana > 0 ? 'text-red-400' : 'text-slate-400' %> mt-1">
              +<%= @novos_pendentes_semana %> esta semana
            </p>
          </div>
          <div class="w-12 h-12 bg-red-900/30 rounded-lg flex items-center justify-center">
            <i data-feather="clock" class="text-red-400"></i>
          </div>
        </div>
      </div>

      <!-- Reportes por resolver -->
      <div class="stat-card rounded-xl shadow-lg p-6 border-l-4 <%= @reportes_por_resolver > 0 ? 'border-orange-500' : 'border-slate-500' %>">
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-slate-400">Reportes por Resolver</p>
            <p class="text-2xl font-bold <%= @reportes_por_resolver > 0 ? 'text-orange-400' : 'text-white' %>"><%= @reportes_por_resolver %></p>
            <p class="text-xs <%= @novos_reportes_semana > 0 ? 'text-red-400' : 'text-slate-400' %> mt-1">
              +<%= @novos_reportes_semana %> esta semana
            </p>
          </div>
          <div class="w-12 h-12 bg-orange-900/30 rounded-lg flex items-center justify-center">
            <i data-feather="alert-triangle" class="text-orange-400"></i>
          </div>
        </div>
      </div>

    </div>

    <!-- Grelha de cards secundários: 2 colunas iguais + tabela em baixo -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">

      <!-- Utilizadores por tipo -->
      <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
        <h3 class="text-lg font-semibold text-white mb-4">Utilizadores por Tipo</h3>
        <div class="space-y-4">

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-blue-400"></div>
              <span class="text-slate-400">Jogadores</span>
            </div>
            <div class="text-right">
              <span class="text-blue-400 font-bold"><%= @total_jogadores %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_jogadores %> esta semana</span>
            </div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-green-400"></div>
              <span class="text-slate-400">Treinadores</span>
            </div>
            <div class="text-right">
              <span class="text-green-400 font-bold"><%= @total_treinadores %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_treinadores %> esta semana</span>
            </div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-purple-400"></div>
              <span class="text-slate-400">Administradores</span>
            </div>
            <div class="text-right">
              <span class="text-purple-400 font-bold"><%= @total_admins %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_admins %> esta semana</span>
            </div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-cyan-400"></div>
              <span class="text-slate-400">Direção de Clube</span>
            </div>
            <div class="text-right">
              <span class="text-cyan-400 font-bold"><%= @total_board %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_board %> esta semana</span>
            </div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-emerald-400"></div>
              <span class="text-slate-400">Clubes</span>
            </div>
            <div class="text-right">
              <span class="text-emerald-400 font-bold"><%= @total_clubes %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_clubes %> esta semana</span>
            </div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-rose-400"></div>
              <span class="text-slate-400">Adeptos</span>
            </div>
            <div class="text-right">
              <span class="text-rose-400 font-bold"><%= @total_adeptos %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_adeptos %> esta semana</span>
            </div>
          </div>

        </div>
      </div>

      <!-- Rede Social -->
      <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
        <h3 class="text-lg font-semibold text-white mb-4">Rede Social</h3>
        <div class="space-y-4">

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-blue-400"></div>
              <span class="text-slate-400">Follows</span>
            </div>
            <div class="text-right">
              <span class="text-blue-400 font-bold"><%= @total_follows %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_follows_semana %> esta semana</span>
            </div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-pink-400"></div>
              <span class="text-slate-400">Likes</span>
            </div>
            <div class="text-right">
              <span class="text-pink-400 font-bold"><%= @total_likes %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_likes_semana %> esta semana</span>
            </div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-indigo-400"></div>
              <span class="text-slate-400">Comentários</span>
            </div>
            <div class="text-right">
              <span class="text-indigo-400 font-bold"><%= @total_comentarios %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_comentarios_semana %> esta semana</span>
            </div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-yellow-400"></div>
              <span class="text-slate-400">Posts Guardados</span>
            </div>
            <div class="text-right">
              <span class="text-yellow-400 font-bold"><%= @total_saves %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novos_saves_semana %> esta semana</span>
            </div>
          </div>

          <div class="flex justify-between items-center">
            <div class="flex items-center gap-2">
              <div class="w-2 h-2 rounded-full bg-slate-400"></div>
              <span class="text-slate-400">Visualizações</span>
            </div>
            <div class="text-right">
              <span class="text-slate-300 font-bold"><%= @total_views %></span>
              <span class="text-xs text-green-400 ml-2">+<%= @novas_views_semana %> esta semana</span>
            </div>
          </div>

        </div>
      </div>

    </div>

    <!-- Tabela de desportos — linha completa -->
    <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
      <h3 class="text-lg font-semibold text-white mb-4">Por Desporto</h3>
      <table class="w-full text-sm">
        <thead>
          <tr class="text-xs text-slate-500 uppercase tracking-wider border-b border-slate-700">
            <th class="pb-3 text-left font-medium">Desporto</th>
            <th class="pb-3 text-center font-medium">Clubes</th>
            <th class="pb-3 text-center font-medium">Jogadores</th>
            <th class="pb-3 text-center font-medium">Treinadores</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-700/50">
          <% @desportos.each do |d| %>
            <tr>
              <td class="py-3 font-medium text-white"><%= d[:nome] %></td>
              <td class="py-3 text-center text-slate-300"><%= d[:clubes] %></td>
              <td class="py-3 text-center">
                <span class="text-slate-300"><%= d[:jogadores] %></span>
                <span class="text-xs text-green-400 ml-1">(+<%= d[:novos_jogadores] %> esta semana)</span>
              </td>
              <td class="py-3 text-center">
                <span class="text-slate-300"><%= d[:treinadores] %></span>
                <span class="text-xs text-green-400 ml-1">(+<%= d[:novos_treinadores] %> esta semana)</span>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

  </div>
</div>


        </div>
</div>
    <script>
        feather.replace();
    </script>

</body>



<style>

    h1 {
        font-size: 16px;
        margin-top: 0;
    }

    p {
        color: rgb(107, 114, 128);
        font-size: 15px;
        margin-bottom: 10px;
        margin-top: 5px;
    }

    .card {
        max-width: 620px;
        margin: 0 auto;
        padding: 16px;
        border: 1px solid lightgray;
        border-radius: 16px;
    }

    .card p:last-child {
        margin-bottom: 0;
    }

    .sidebar-icon {
        transition: all 0.3s ease;
    }
    
    .sidebar-item:hover .sidebar-icon {
        transform: translateX(5px);
    }
    
    .stat-card {
        background: rgba(30, 41, 59, 0.8);
    }
    
    .glow {
        box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
    }
</style>
