<body class="min-h-screen flex text-white bg-gray-900">
<!---------------------------------------------------- NOME E LOGO DO CLUBE ---------------------------------------------------->
    <div class="w-64 bg-slate-800 shadow-xl min-h-screen flex flex-col border-r border-slate-700">
    <!-- Logo e nome do clube -->
        <div class="p-6 border-b border-slate-700">
            <div class="flex items-center justify-center mb-3">
                
                <% if current_user.admin_profile.profile_picture.attached? %>
                    <%= image_tag url_for(current_user.admin_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-20 h-20 rounded-full border-1" %>
                <% end %>

                
            </div>
            <h1 class="text-lg font-bold text-center text-white">
                <%= current_user.admin_profile.name %>
            </h1>
        </div>
<!---------------------------------------------------- OPÇÕES DO SIDEBAR ---------------------------------------------------->
        <nav class="flex-1 p-4 space-y-2">
            
            <%= link_to admin_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-blue-400 rounded-xl border-l-4 border-transparent hover:border-blue-500 transition-all duration-300">
                <i data-feather="home" class="sidebar-icon text-blue-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Dashboard</span>
            </div>
            <% end %>

            <% if current_user.admin_profile.super? %>
              <%= link_to list_admins_dashboard_path do %>
              <div class="sidebar-item flex items-center px-4 py-3 bg-slate-700 text-purple-400 rounded-xl border-l-4 border-purple-500 transition-all duration-300">
                  <i data-feather="user" class="sidebar-icon text-purple-400 w-5 h-5 mr-3"></i>
                  <span class="font-medium">Admins</span>
              </div>
              <% end %>
            <% end %>

            <%= link_to club_verification_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-green-400 rounded-xl border-l-4 border-transparent hover:border-green-500 transition-all duration-300">
                <i data-feather="users" class="sidebar-icon text-green-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Verificação de Clubes</span>
            </div>
            <% end %>


            <%= link_to reports_dashboard_path do %>
            <div  class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-yellow-400 rounded-xl border-l-4 border-transparent hover:border-yellow-500 transition-all duration-300">
                <i data-feather="alert-triangle" class="sidebar-icon text-yellow-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Reports</span>
            </div>
            <% end %>

            <%= link_to bans_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-red-400 rounded-xl border-l-4 border-transparent hover:border-red-500 transition-all duration-300">
                <i data-feather="slash" class="sidebar-icon text-red-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Bans</span>
            </div>
            <% end %>

            <%= link_to root_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-gray-400 rounded-xl border-l-4 border-transparent hover:border-gray-400 transition-all duration-300">
                <i data-feather="arrow-left" class="sidebar-icon text-gray-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Página Inicial</span>
            </div>
            <% end %>
        </nav>


        <div class="p-4 border-t border-slate-700">
            <div class="flex items-center space-x-3">
                <% if current_user.admin_profile.profile_picture.attached? %>
                    <%= image_tag url_for(current_user.admin_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% end %>
                <div class="flex-1">
                        <p class="text-sm font-medium text-white"> <%= current_user.admin_profile.name %> </p>
                </div>
                <%= button_to destroy_user_session_path, method: :delete do %>
                    <i data-feather="log-out" class="text-slate-400 hover:text-red-400 cursor-pointer transition-colors"></i>
                <% end %>
            </div>
        </div>
</div>
<!-------------------------------------------------------------------------------- MAIN ------------------------------------------------------------------------->
    <div class="flex-1 p-8">

            <div class="flex justify-between items-center mb-8">
                <div>
                    <h1 class="text-3xl font-bold text-purple-500 slide-in">Admins</h1>
                    <p class="text-slate-400 mt-1">Gerencie todos os admins da plataforma!</p> 
                </div>
            </div>
            <br>

            <!---------------------------------------------------- PESQUISAS ---------------------------------------------------->
            <div class="flex items-center mb-6 gap-x-4">
                <%= form_with url: list_admins_dashboard_path, method: :get, local: true, id: "search-form" do %>
                    <%= hidden_field_tag :type, @admin_type %>
                    <div class="relative w-80">
                        <i data-feather="search" class="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 w-4 h-4 pointer-events-none z-10"></i>
                        <%= text_field_tag :query, params[:query], placeholder: "Pesquisar Admins", class: "bg-gray-800 border border-gray-700 rounded-lg pl-10 pr-10 py-2 w-full focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent text-white", oninput: "clearTimeout(window.searchTimeout); window.searchTimeout = setTimeout(() => this.form.requestSubmit(), 1000); toggleClearButton(this)", id: "search-input" %>
                        <button type="button" id="clear-search" onclick="clearSearch()" class="absolute right-3 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-white transition <%= 'hidden' unless params[:query].present? %>">
                            <i data-feather="x" class="w-4 h-4 text-red-400"></i>
                        </button>
                    </div>
                <% end %>

                <%= link_to list_admins_dashboard_path(type: "Todos") do %>
                    <button class="px-6 py-2 rounded-full border transition-all duration-200 <%= @admin_type == "Todos" ? 'bg-blue-600 border-blue-500 text-white' : 'bg-gray-800 border-gray-600 text-gray-300 hover:border-blue-500 hover:text-blue-400 hover:bg-blue-500/10' %>">Todos</button>
                <% end %>
                <%= link_to list_admins_dashboard_path(type: "Super Admin") do %>
                    <button class="px-6 py-2 rounded-full border transition-all duration-200 <%= @admin_type == "Super Admin" ? 'bg-blue-600 border-blue-500 text-white' : 'bg-gray-800 border-gray-600 text-gray-300 hover:border-blue-500 hover:text-blue-400 hover:bg-blue-500/10' %>">Super Admins</button>
                <% end %>
                <%= link_to list_admins_dashboard_path(type: "Admin Regular") do %>
                    <button class="px-6 py-2 rounded-full border transition-all duration-200 <%= @admin_type == "Admin Regular" ? 'bg-blue-600 border-blue-500 text-white' : 'bg-gray-800 border-gray-600 text-gray-300 hover:border-blue-500 hover:text-blue-400 hover:bg-blue-500/10' %>">Admins Regulares</button>
                <% end %>

            </div>

            
<!-------------------------------------------------------------------------------- Admins ------------------------------------------------------------------------->

            <div class="mb-12">
                <% if !params[:query].present? or (params[:query].present? and @admins_count != 0) %>
                    <div class="flex items-center justify-between mb-6">
                        <h3 class="text-xl font-bold text-secondary-300 flex items-center space-x-2">
                            <i data-feather="users" class="w-6 h-6"></i>
                            <span>Admins ( <%= @admins_count %> )</span>
                        </h3>

                        <div class="flex items-center gap-4">
                            <%= link_to new_admin_profile_registration_path do %>
                                <button class="bg-green-700 hover:bg-green-800 text-white px-4 py-2 rounded-lg flex items-center space-x-2 transition-all duration-200 transform hover:scale-105">
                                    <i data-feather="user-plus" class="w-4 h-4"></i>
                                </button>
                            <% end %>
                        </div>
                    </div>
                <% end %>

                <% if params[:query].present? and @admins_count == 0 %>
                    <br>
                    <div class="flex justify-center items-center mb-8">
                        <div class="flex flex-col items-start">
                            <h1 class="text-2xl text-neutral-400 slide-in mx-auto">A pesquisa "<%= params[:query] %>" não retornou nenhum admin! </h1>
                        </div>
                    </div>
                <% end %>

                <% if @admins&.any? %>
                    <div class="grid grid-cols-4 justify-center gap-6">
                    <% @admins.each do |admin| %>
                        <div class="bg-gray-800 border-l-4 border-secondary-300 rounded-xl overflow-hidden transition-all hover:scale-[1.01] hover:shadow-lg hover:shadow-primary/10 relative">
                            <%= link_to admin_profile_path(admin) do %>
                                <div class="relative h-40 bg-gradient-to-r from-primary/20 to-secondary/20">
                                    <div class="relative w-full h-40 rounded-lg overflow-hidden shadow-lg">
                                        <% if admin.banner_picture.attached? %>
                                            <%= image_tag url_for(admin.banner_picture), class: "w-full h-full object-cover" %>
                                        <% else %>
                                            <%= image_tag "default_banner.jpg", class: "w-full h-full object-cover" %>
                                        <% end %>
                                    </div>
                                    <div class="absolute top-20 left-4 w-32 h-32 rounded-full overflow-hidden border-4 border-white shadow-lg bg-gray-100 group">
                                        <% if admin.profile_picture.attached? %>
                                            <%= image_tag url_for(admin.profile_picture), class: "w-full h-full object-cover " %>
                                        <% else %>
                                            <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover " %>
                                        <% end %>
                                    </div>
                                </div>
                                <div class="p-4 pt-14 pb-4">
                                    <div class="flex justify-between items-start">
                                        <div>
                                            <h3 class="font-bold text-lg"> <%= admin.name %> </h3>
                                            <p class="text-gray-400 text-sm"> <%= admin.role %>
                                        </div>
                                    </div>
                                </div>
                            <% end %>
                        </div>
                    <% end %>
                <% end %>

                </div> 

                <% if @admins.total_pages > 1 %>
                <div class="mt-8 flex justify-end">
                    <div class="flex flex-col items-end gap-3">               

                    <div class="flex items-center gap-2">
                        <% if @admins.prev_page %>
                        <%= link_to list_admins_dashboard_path(type: @admin_type, query: params[:query], admin_page: @admins.prev_page), class: "flex items-center gap-2 px-4 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white rounded-lg border border-gray-700 transition-all duration-200 font-medium" do %>
                            <i data-feather="chevron-left" class="w-4 h-4"></i>
                            <span>Anterior</span>
                        <% end %>
                        <% else %>
                        <div class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/50 text-gray-600 rounded-lg border border-gray-700/50 cursor-not-allowed font-medium">
                            <i data-feather="chevron-left" class="w-4 h-4"></i>
                            <span>Anterior</span>
                        </div>
                        <% end %>

                        <div class="flex items-center gap-1">
                        <% (1..@admins.total_pages).each do |page| %>
                            <% if page == @admins.current_page %>
                            <div class="w-10 h-10 flex items-center justify-center rounded-lg bg-purple-600 text-white font-bold border-2 border-purple-500 shadow-lg">
                                <%= page %>
                            </div>
                            <% else %>
                            <%= link_to page, list_admins_dashboard_path(type: @admin_type, query: params[:query], admin_page: page), class: "w-10 h-10 flex items-center justify-center rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white border border-gray-700 transition-all duration-200 font-medium" %>
                            <% end %>
                        <% end %>
                        </div>

                        <% if @admins.next_page %>
                        <%= link_to list_admins_dashboard_path(type: @admin_type, query: params[:query], admin_page: @admins.next_page), class: "flex items-center gap-2 px-4 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 hover:text-white rounded-lg border border-gray-700 transition-all duration-200 font-medium" do %>
                            <span>Seguinte</span>
                            <i data-feather="chevron-right" class="w-4 h-4"></i>
                        <% end %>
                        <% else %>
                        <div class="flex items-center gap-2 px-4 py-2.5 bg-gray-800/50 text-gray-600 rounded-lg border border-gray-700/50 cursor-not-allowed font-medium">
                            <span>Seguinte</span>
                            <i data-feather="chevron-right" class="w-4 h-4"></i>
                        </div>
                        <% end %>
                    </div>
                    </div>
                </div>

                <% elsif !@admins&.any? and !params[:query].present? %>
                    <div class="flex justify-center items-center mb-8">
                        <div class="flex flex-col items-start">
                            <h1 class="text-2xl text-neutral-400 slide-in mx-auto">Ainda não existe nenhum admin!</h1>
                        </div>
                    </div>
                <% end %>
                
            </div>
            
    </div>

<script>
    feather.replace()
</script>

