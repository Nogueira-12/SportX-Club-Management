<body class="min-h-screen flex text-white bg-gray-900">
<!---------------------------------------------------- NOME E LOGO DO CLUBE ---------------------------------------------------->
    <div class="w-64 bg-slate-800 shadow-xl min-h-screen flex flex-col border-r border-slate-700">
    <!-- Logo e nome do clube -->
        <div class="p-6 border-b border-slate-700">
            <div class="flex items-center justify-center mb-3">
                
                <% if (current_user.club? and current_user.club_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.club_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% elsif (current_user.board? && current_user.board_profile.club_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.board_profile.club_profile.profile_picture), class: "w-20 h-20 rounded-full border-1" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-20 h-20 rounded-full border-1" %>
                <% end %>

                
            </div>
            <h1 class="text-lg font-bold text-center text-white">
                <% if current_user.club? %>
                    <%= current_user.club_profile.name %>
                <% elsif current_user.board? %>
                    <%= current_user.board_profile.club_profile.name %>
                <% end %>
            </h1>
        </div>
<!---------------------------------------------------- OPÇÕES DO SIDEBAR ---------------------------------------------------->
        <nav class="flex-1 p-4 space-y-2">
            
            <%= link_to club_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 bg-slate-700 text-blue-400 rounded-xl border-l-4 border-blue-500 transition-all duration-300">
                <i data-feather="home" class="sidebar-icon text-blue-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Dashboard</span>
            </div>
            <% end %>

            <%= link_to club_teams_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-green-400 rounded-xl border-l-4 border-transparent hover:border-green-500 transition-all duration-300">
                <i data-feather="users" class="sidebar-icon text-green-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Equipas</span>
            </div>
            <% end %>


            <%= link_to club_finances_dashboard_path do %>
            <div  class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-yellow-400 rounded-xl border-l-4 border-transparent hover:border-yellow-500 transition-all duration-300">
                <i data-feather="dollar-sign" class="sidebar-icon text-yellow-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Finanças</span>
            </div>
            <% end %>



            <%= link_to club_infrastructures_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-orange-400 rounded-xl border-l-4 border-transparent hover:border-orange-500 transition-all duration-300">
                <i data-feather="map-pin" class="sidebar-icon text-orange-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Infraestruturas</span>
            </div>
            <% end %>

            <%= link_to club_equipment_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-rose-400 rounded-xl border-l-4 border-transparent hover:border-rose-300 transition-all duration-300">
                <i data-feather="clipboard" class="sidebar-icon text-rose-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Material</span>
            </div>
            <% end %>

            <%= link_to club_board_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-rose-900 rounded-xl border-l-4 border-transparent hover:border-rose-950 transition-all duration-300">
                <i data-feather="settings" class="sidebar-icon text-rose-900 w-5 h-5 mr-3"></i>
                <span class="font-medium">Membros da Direção</span>
            </div>
            <% end %>

            <%= link_to club_invitations_dashboard_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-purple-500 rounded-xl border-l-4 border-transparent hover:border-purple-950 transition-all duration-300">
                <i data-feather="mail" class="sidebar-icon text-purple-500 w-5 h-5 mr-3"></i>
                <span class="font-medium">Convites</span>
            </div>
            <% end %>

            <%= link_to root_path do %>
            <div class="sidebar-item flex items-center px-4 py-3 text-slate-300 hover:bg-slate-700 hover:text-gray-400 rounded-xl border-l-4 border-transparent hover:border-gray-400 transition-all duration-300">
                <i data-feather="arrow-left" class="sidebar-icon text-gray-400 w-5 h-5 mr-3"></i>
                <span class="font-medium">Página Inicial</span>
            </div>
            <% end %>
        </nav>


        <div class="p-4 border-t border-slate-700">
            <div class="flex items-center space-x-3">
                <% if (current_user.club? and current_user.club_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.club_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% elsif (current_user.board? and current_user.board_profile.profile_picture.attached?) %>
                    <%= image_tag url_for(current_user.board_profile.profile_picture), class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-10 h-10 rounded-full border-2 border-slate-600" %>
                <% end %>
                <div class="flex-1">
                    <% if current_user.club? %>
                        <p class="text-sm font-medium text-white"> <%= current_user.club_profile.name %> </p>
                    <% elsif current_user.board? %>
                        <p class="text-sm font-medium text-white"> <%= current_user.board_profile.name %> </p>
                    <% end %>
                </div>
                <%= button_to destroy_user_session_path, method: :delete do %>
                    <i data-feather="log-out" class="text-slate-400 hover:text-red-400 cursor-pointer transition-colors"></i>
                <% end %>
            </div>
        </div>
</div>





<!---------------------------------------------------- MAIN CONTENT ---------------------------------------------------->
    <div class="flex-1 p-8 overflow-auto">
        <!-- Header -->
        <div class="flex justify-between items-center mb-8">
            <div>
                <h1 class="text-3xl font-bold slide-in text-blue-400">Dashboard</h1>
                <p class="text-slate-400 mt-1">Veja algumas das estatisticas mais importantes do seu clube! </p>
            </div>
        </div>
        <% if @club_profile.verified? %>
        <!-- Stats Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">

        <div class="stat-card rounded-xl shadow-lg p-6 border-l-4 border-blue-500 glow">
        <div class="flex items-center justify-between">
            <div>
            <p class="text-sm text-slate-400">Total de Membros</p>
            <p class="text-2xl font-bold text-white"><%= @total_jogadores + @total_treinadores %></p>
            <p class="text-xs text-slate-400 mt-1"><%= @total_jogadores %> jogadores · <%= @total_treinadores %> treinadores</p>
            </div>
            <div class="w-12 h-12 bg-blue-900/30 rounded-lg flex items-center justify-center">
            <i data-feather="users" class="text-blue-400"></i>
            </div>
        </div>
        </div>

        <div class="stat-card rounded-xl shadow-lg p-6 border-l-4 border-green-500 glow">
        <div class="flex items-center justify-between">
            <div>
            <p class="text-sm text-slate-400">Equipas Ativas</p>
            <p class="text-2xl font-bold text-white"><%= @total_equipas %></p>
            <p class="text-xs text-slate-400 mt-1"><%= @jogadores_sem_equipa + @treinadores_sem_equipa%> membros sem equipa</p>
            </div>
            <div class="w-12 h-12 bg-green-900/30 rounded-lg flex items-center justify-center">
            <i data-feather="activity" class="text-green-400"></i>
            </div>
        </div>
        </div>

        <div class="stat-card rounded-xl shadow-lg p-6 border-l-4 border-yellow-500 glow">
        <div class="flex items-center justify-between">
            <div>
            <p class="text-sm text-slate-400">Saldo Atual</p>
            <p class="text-2xl font-bold text-white">
                <%= @saldo ? number_to_currency(@saldo.value, unit: "€", separator: ",", delimiter: ".", format: "%n %u") : "—" %>
            </p>
            <p class="text-xs <%= @balanco_mes >= 0 ? 'text-green-400' : 'text-red-400' %> mt-1">
                <%= @balanco_mes >= 0 ? '↑' : '↓' %> <%= number_to_currency(@balanco_mes.abs, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %> este mês
            </p>
            </div>
            <div class="w-12 h-12 bg-yellow-900/30 rounded-lg flex items-center justify-center">
            <i data-feather="dollar-sign" class="text-yellow-400"></i>
            </div>
        </div>
        </div>

        <div class="stat-card rounded-xl shadow-lg p-6 border-l-4 border-purple-500 glow">
        <div class="flex items-center justify-between">
            <div>
            <p class="text-sm text-slate-400">Treinos esta Semana</p>
            <p class="text-2xl font-bold text-white"><%= @treinos_esta_semana %></p>
            <p class="text-xs text-slate-400 mt-1"><%= @total_campos %> campos · <%= @total_balnearios %> balneários</p>
            </div>
            <div class="w-12 h-12 bg-purple-900/30 rounded-lg flex items-center justify-center">
            <i data-feather="calendar" class="text-purple-400"></i>
            </div>
        </div>
        </div>
        </div>
        <!-- Statistics Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">

        <%# Jogadores por Desporto %>
        <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
        <h3 class="text-lg font-semibold text-white mb-4">Membros por Desporto</h3>
        <div class="space-y-4">
            <div class="flex justify-between items-center">
            <span class="text-slate-400">Jogadores de Futebol</span>
            <span class="text-blue-400 font-bold"><%= @jogadores_futebol %></span>
            </div>
            <div class="flex justify-between items-center">
            <span class="text-slate-400">Jogadores de Andebol</span>
            <span class="text-purple-400 font-bold"><%= @jogadores_andebol %></span>
            </div>
            <div class="flex justify-between items-center">
            <span class="text-slate-400">Treinadores de Futebol</span>
            <span class="text-blue-400 font-bold"><%= @treinadores_futebol %></span>
            </div>
            <div class="flex justify-between items-center">
            <span class="text-slate-400">Treinadores de Andebol</span>
            <span class="text-purple-400 font-bold"><%= @treinadores_andebol %></span>
            </div>
        </div>
        </div>

    <%# Próximos Treinos %>
    <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
    <h3 class="text-lg font-semibold text-white mb-4">Próximos Treinos</h3>
    <div class="space-y-4">
        <% if @proximos_treinos.any? %>
        <% @proximos_treinos.each do |treino| %>
            <div class="flex justify-between items-center">
            <div>
                <p class="text-white text-sm font-medium mb-0 mt-0 ">
                    <%= treino.name.present? ? treino.name : "Treino" %>
                </p>
                <p class="text-slate-500 text-xs mb-0 mt-0"><%= treino.club_team.name %> -  <%= treino.club_team.sport_id == 2 ? "Futebol" : "Andebol" %> </p>
            </div>
            <span class="text-indigo-400 font-bold text-sm whitespace-nowrap">
                <%= l(treino.start_time, format: " %d/%m - %H:%M") %>
            </span>
            </div>
        <% end %>
        <% else %>
        <p class="text-slate-500 text-sm">Sem treinos para esta semana</p>
        <% end %>
    </div>
    </div>

    <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
    <h3 class="text-lg font-semibold text-white mb-4">Maiores Receitas - <%= l(Date.current, format: "%B") %></h3>
    <div class="space-y-4">
        <% if @top_receitas.any? %>
        <% @top_receitas.each do |receita| %>
            <div class="flex justify-between items-center">
            <span class="text-slate-400 truncate mr-2"><%= receita.description.presence || "Sem descrição" %></span>
            <span class="text-green-400 font-bold whitespace-nowrap">
                + <%= number_to_currency(receita.value, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %>
            </span>
            </div>
        <% end %>
        <% else %>
        <p class="text-slate-500 text-sm">Sem receitas este mês</p>
        <% end %>
    </div>
    </div>

    <%# Material %>
    <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
    <h3 class="text-lg font-semibold text-white mb-4">Material</h3>
    <div class="space-y-4">
        <div class="flex justify-between items-center">
        <span class="text-slate-400">Total de Materiais</span>
        <span class="text-white font-bold"><%= @total_materiais %></span>
        </div>
        <div class="flex justify-between items-center">
        <span class="text-slate-400">Materiais Esgotados</span>
        <span class="<%= @materiais_esgotados > 0 ? 'text-red-400' : 'text-green-400' %> font-bold"><%= @materiais_esgotados %></span>
        </div>
        <div class="flex justify-between items-center">
        <span class="text-slate-400">Material de Futebol</span>
        <span class="text-blue-400 font-bold"><%= @materiais_futebol %></span>
        </div>
        <div class="flex justify-between items-center">
        <span class="text-slate-400">Material de Andebol</span>
        <span class="text-purple-400 font-bold"><%= @materiais_andebol %></span>
        </div>
    </div>
    </div>

    <%# Últimas Transações %>
    <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
    <h3 class="text-lg font-semibold text-white mb-4">Últimas Transações</h3>
    <div class="space-y-4">
        <% if @ultimas_transacoes.any? %>
        <% @ultimas_transacoes.each do |t| %>
            <div class="flex justify-between items-center">
            <div>
                <p class="text-white text-sm font-medium mb-0 mt-0">
                <%= t[:descricao].presence || "Sem descrição" %>
                </p>
                <p class="text-slate-500 text-xs mb-0 mt-0"><%= t[:data].strftime("%d/%m/%Y") %></p>
            </div>
            <span class="<%= t[:tipo] == :receita ? 'text-green-400' : 'text-red-400' %> font-bold whitespace-nowrap">
                <%= t[:tipo] == :receita ? '+' : '-' %>
                <%= number_to_currency(t[:valor], unit: "€", separator: ",", delimiter: ".", format: "%n %u") %>
            </span>
            <%# t[:tipo] == :receita — compara o símbolo guardado no hash para saber a cor e o sinal %>
            </div>
        <% end %>
        <% else %>
        <p class="text-slate-500 text-sm">Sem transações recentes</p>
        <% end %>
    </div>
    </div>

    <div class="bg-slate-800 rounded-xl shadow-lg p-6 border border-slate-700">
    <h3 class="text-lg font-semibold text-white mb-4">Maiores Despesas - <%= l(Date.current, format: "%B") %></h3>
    <div class="space-y-4">
        <% if @top_despesas.any? %>
        <% @top_despesas.each do |despesa| %>
            <div class="flex justify-between items-center">
            <span class="text-slate-400 truncate mr-2"><%= despesa.description.presence || "Sem descrição" %></span>
            <span class="text-red-400 font-bold whitespace-nowrap">
                - <%= number_to_currency(despesa.value, unit: "€", separator: ",", delimiter: ".", format: "%n %u") %>
            </span>
            </div>
        <% end %>
        <% else %>
        <p class="text-slate-500 text-sm">Sem despesas este mês</p>
        <% end %>
    </div>
    </div>
        </div>
</div>
    

<% else %>
    <div class="flex justify-center items-center mb-8">
        <div class="flex flex-col items-start">
        <% if @club_profile.verification_pending? %>
            <div class="flex justify-center mt-16 px-4">
                <div class="flex flex-col items-center p-8 text-yellow-100 rounded-2xl bg-yellow-700/20 border border-yellow-600/40 text-center max-w-md w-full shadow-lg">
                    <div class="w-16 h-16 rounded-full bg-yellow-600/30 flex items-center justify-center mb-4">
                        <svg class="w-8 h-8 text-yellow-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
                        </svg>
                    </div>
                    <span class="text-xl font-bold mb-2">Verificação Pendente</span>
                    <span class="text-sm text-yellow-200/80">Esta secção será desbloqueada uma vez que o clube esteja verificado</span>
                </div>
            </div>
        <% elsif @club_profile.verification_rejected? %>
            <div class="flex justify-center mt-16 px-4">
                <div class="flex flex-col items-center p-8 text-red-100 rounded-2xl bg-red-700/20 border border-red-600/40 text-center max-w-md w-full shadow-lg">
                    <div class="w-16 h-16 rounded-full bg-red-600/30 flex items-center justify-center mb-4">
                        <svg class="w-8 h-8 text-red-300" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 20 20">
                            <path d="M10 .5a9.5 9.5 0 1 0 9.5 9.5A9.51 9.51 0 0 0 10 .5ZM9.5 4a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3ZM12 15H8a1 1 0 0 1 0-2h1v-3H8a1 1 0 0 1 0-2h2a1 1 0 0 1 1 1v4h1a1 1 0 0 1 0 2Z"/>
                        </svg>
                    </div>
                    <span class="text-xl font-bold mb-2">Verificação Rejeitada</span>
                    <span class="text-sm text-red-200/80">Esta secção será desbloqueada uma vez que o clube esteja verificado</span>
                </div>
            </div>
        <% end %>
        </div>  
    </div>
<% end %>

</body>

<script>
        feather.replace();
    </script>

<style>

    h1 {
        font-size: 16px;
        margin-top: 0;
    }

    p {
        color: rgb(107, 114, 128);
        font-size: 15px;
        margin-bottom: 10px;
        margin-top: 5px;
    }

    .card {
        max-width: 620px;
        margin: 0 auto;
        padding: 16px;
        border: 1px solid lightgray;
        border-radius: 16px;
    }

    .card p:last-child {
        margin-bottom: 0;
    }

    .sidebar-icon {
        transition: all 0.3s ease;
    }
    
    .sidebar-item:hover .sidebar-icon {
        transform: translateX(5px);
    }
    
    .stat-card {
        background: rgba(30, 41, 59, 0.8);
    }
    
    .glow {
        box-shadow: 0 0 20px rgba(59, 130, 246, 0.3);
    }
</style>
