<body class="bg-gray-900 text-gray-100 min-h-screen">
    <!-- Banner -->
    <div class="relative h-64 bg-gradient-to-r from-indigo-900 to-purple-900 overflow-hidden">
        <button onclick="window.location.href='/'" class="absolute top-4 left-4 z-20 flex items-center gap-2 px-3 py-2 bg-red-800 bg-opacity-50 hover:bg-opacity-85 rounded-lg transition text-white">
            <i data-feather="arrow-left"></i>
            <span>Voltar</span>
        </button>
        <div class="absolute inset-0 bg-black opacity-30"></div>
        <div class="relative h-full flex items-center justify-center">
            <% if club_profile.banner_picture.attached? %>
                <%= image_tag url_for(club_profile.banner_picture), class: "w-full h-full object-cover" %>
            <% else %>
                <%= image_tag "default_banner.jpg", class: "w-full h-full object-cover" %>
            <% end %>
        </div>
    </div>
    <!-- Profile Picture -->
    <div class="container mx-auto px-4 -mt-12 relative z-10">
        <div class="flex flex-col md:flex-row items-center md:items-end gap-6">
            <div id="profile-pic-container" class="profile-pic w-32 h-32 md:w-40 md:h-40 rounded-full bg-gray-800 overflow-hidden border-4 border-gray-700 shadow-xl cursor-pointer group relative">
                <% if club_profile.profile_picture.attached? %>
                    <%= image_tag url_for(club_profile.profile_picture), class: "w-full h-full object-cover", id: "profile-pic-img" %>
                <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover", id: "profile-pic-img" %>
                <% end %>
            </div>
            <!-- Club Name and follow buttons -->
            <div class="flex-1">
                <div class="flex items-center gap-4">
                    <h2 class="mt-6 text-2xl md:text-3xl font-bold py-1 whitespace-nowrap flex-shrink-0"><%= club_profile.name %></h2>
                </div>
                <!-- Botão editar campos -->
                <div class="flex items-center gap-4 mt-4">
                    <% if !club_profile.user.banned? %>
                        <% if current_user && current_user.id == club_profile.user_id %>
                            <%= link_to edit_club_profile_path(club_profile), class: "flex items-center gap-2 px-4 py-2 bg-blue-700 hover:bg-blue-800 rounded-lg transition" do %>
                                    <i data-feather="edit"></i>
                                    <span>Editar Perfil</span>
                                <% end %>
                            <% if club_profile.verification_rejected? %>
                                <button data-modal-target="appeal-verification" data-modal-toggle="appeal-verification" class="flex items-center gap-2 px-4 py-2 bg-yellow-600 hover:bg-yellow-800 rounded-lg transition text-lg">
                                    Solicitar Nova Verificação
                                </button>
                            <% end %>
                        <% else %>
                            <% if current_user.club? and !current_user.club_profile.verified? %>
                                        <button type="disabled" class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg font-medium text-sm transition whitespace-nowrap w-20 flex-shrink-0 cursor-not-allowed">
                                            Seguir
                                        </button>
                                        <button type="disabled" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded-lg font-medium text-sm transition whitespace-nowrap flex-shrink-0 flex items-center gap-2 cursor-not-allowed">
                                            <i data-feather="alert-triangle" class="w-4 h-4"></i>
                                            Reportar
                                        </button>
                                    <% else %>
                                        <%= render "follows/follow_button_suggestions", user: club_profile.user %>
                                        <button data-modal-toggle="modal-report" data-modal-target="modal-report" class="bg-yellow-600 hover:bg-yellow-800 text-white px-4 py-2 rounded-lg font-medium text-sm transition whitespace-nowrap flex-shrink-0 flex items-center gap-2">
                                            <i data-feather="alert-triangle" class="w-4 h-4"></i>
                                            Reportar
                                        </button>
                                    <% end %>
                        <% end %>
                    <% end %>
                    <% if current_user.admin? and !club_profile.user.banned? %>
                        <button data-modal-toggle="ban-modal" data-modal-target="ban-modal" class="bg-red-600 hover:bg-red-800 text-white px-4 py-2 rounded-lg font-medium text-sm transition whitespace-nowrap flex-shrink-0 flex items-center gap-2">
                            <i data-feather="slash" class="w-4 h-4"></i>
                            Banir Utilizador
                        </button>
                    <% elsif current_user.admin? and club_profile.user.banned? %>
                        <button data-modal-toggle="unban-modal" data-modal-target="unban-modal" class="bg-yellow-600 hover:bg-yellow-800 text-white px-4 py-2 rounded-lg font-medium text-sm transition whitespace-nowrap flex-shrink-0 flex items-center gap-2">
                            <i data-feather="slash" class="w-4 h-4"></i>
                            Revogar Banimento
                        </button>
                    <% end %>
                </div>
            </div>
<% if !club_profile.user.banned? %>
            <!-- Profile Stats -->
            <div class="mt-5 md:mt-0 rounded-xl p-6">
                <div class="flex justify-center text-center gap-8">
                    <div data-modal-target="modal-followers" data-modal-toggle="modal-followers" class="group hover:bg-gray-700 rounded-lg px-4 py-2 transition cursor-pointer">
                        <%= render "follows/followers_count", user: club_profile.user %>
                    </div>
                    <div data-modal-target="modal-following" data-modal-toggle="modal-following" class="group hover:bg-gray-700 rounded-lg px-4 py-2 transition cursor-pointer">
                        <%= render "follows/following_count", user: club_profile.user %>
                    </div>
                    <div class="rounded-lg px-4 py-2 transition">
                        <span class="font-bold text-xl text-gray-100"><%= @posts.count %></span>
                        <% if @posts.count == 1 %>
                            <span class="text-gray-400 transition-colors block text-sm">Publicação</span>
                        <% else %>
                            <span class="text-gray-400 transition-colors block text-sm">Publicações</span>
                        <% end %>
                    </div>
                </div>
            </div>
        </div>
    </div>

<% if club_profile.verified? %>
    <!-- 
    Biography Section -->
    <div class="container mx-auto px-4 py-8">
        <!-- Biography -->
            <div class="bg-gray-800 rounded-xl p-6 shadow-lg fade-in mb-8 border-l-4 border-blue-500">
                <h3 class="text-xl font-bold mb-4 text-blue-300">Biografia</h3>
                <div class="bg-gray-700 rounded-xl py-1 px-8 shadow-lg fade-in whitespace-pre-wrap">
                    <% if club_profile.bio.present? %>
<%= club_profile.bio %>
                    <% else %>
<p class="text-gray-300">Ainda sem biografia</p>
                    <% end %>                    
                </div>
            </div>  
            
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
            <!-- Biography Details -->
            <div class="bg-gray-800 rounded-xl p-6 shadow-lg fade-in space-y-4 border-l-4 border-blue-500">
                <h3 class="text-xl font-bold mb-4 text-blue-300">Info</h3>
                <div class="space-y-6 mt-1"> 
                    <div class="flex items-center gap-3"> 
                        <i data-feather="calendar" class="text-gray-400"></i>
                        <span class="text-gray-300">Data de Fundação: 
                            <% if club_profile.foundation_date.present? -%>
                                <%= l(club_profile.foundation_date, format: :long, locale: :pt) %>
                            <% else -%>
                                <span class="text-gray-400">Não disponível</span>
                            <% end -%>
                        </span>
                    </div> 
                </div> 
                <div class="flex items-start gap-3"> 
                    <i data-feather="award" class="text-gray-400"></i>
                    <div class="text-gray-300">
                        <span>Modalidade(s):</span>
                        <% if club_profile.has_both_sports? %>
                            <span>Futebol | Andebol</span>
                        <% else %>
                            <% if club_profile.has_football? %>
                                <span>Futebol</span>
                            <% elsif club_profile.has_handball? %>
                                <span>Andebol</span>
                            <% else %>
                                <span> Ainda sem desportos</span>
                            <% end %>
                        <% end %>
                    </div>
                </div> 
            </div>

            <!-- Contact Details -->
            <div class="bg-gray-800 rounded-xl p-6 shadow-lg fade-in border-l-4 border-blue-500">
                <h3 class="text-xl font-bold mb-4 text-blue-300">Contactos</h3>
                <div class="space-y-4">
                    <div class="flex items-center gap-3">
                        <i data-feather="phone" class="text-gray-400"></i>
                        <span class="text-gray-300"><%= club_profile.contact || "Contacto não disponível" %></span>
                    </div>
                    <div class="flex items-center gap-3">
                        <i data-feather="mail" class="text-gray-400"></i>
                        <span class="text-gray-300"><%= club_profile.user.email || "Email não disponível" %></span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="container mx-auto px-4 py-2">
        <div class="lg:col-span-3 space-y-8">
            <!-- Posts Section -->
            <div class="space-y-6">
                <div class="flex items-center justify-between">
                    
                    <h3 class="text-xl font-bold text-red-400">Publicações</h3>
                </div>
                
                        <!-- Create Post -->
                        <% if current_user&.id == club_profile.user_id %>
                            <div id="inicio-pub" class="bg-gray-800 rounded-xl p-4 shadow-lg border-l-4 border-red-500">
                                
                                    <%= form_with model: Post.new, url: posts_path, local: false, multipart: true, id: "new_post_form", class: "space-y-4" do |f| %>
                                        <div class="flex items-start space-x-4">
                                            <div class="w-10 h-10 rounded-full bg-gray-700 flex-shrink-0 overflow-hidden flex items-center justify-center">
                                                <% if club_profile.profile_picture.attached? %>
                                                    <%= image_tag url_for(club_profile.profile_picture), class: "w-full h-full object-cover", id: "profile-pic-img" %>
                                                <% else %>
                                                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover", id: "profile-pic-img" %>
                                                <% end %>
                                            </div>
                                            <div class="flex-1">
                                                <%= f.text_area :content, 
                                                    rows: 3,
                                                    placeholder: "O que estás a pensar?",
                                                    class: "w-full bg-gray-700 rounded-lg p-3 text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-blue-500 resize-none" %>

                                                <!-- Image Preview -->
                                                <div id="image-preview-container" class="hidden mt-3 relative">
                                                    <div id="image-carousel" class="flex overflow-x-auto scroll-smooth rounded-lg no-scrollbar gap-2">
                                                        <!-- Images will be injected here by JS -->
                                                    </div>
                                                    <button id="prev-image-btn" class="absolute left-2 top-1/2 transform -translate-y-1/2 bg-gray-800 bg-opacity-75 hover:bg-opacity-100 text-white p-1 rounded-full hidden transition-all z-10">
                                                        <i data-feather="chevron-left" class="w-6 h-6"></i>
                                                    </button>
                                                    <button id="next-image-btn" class="absolute right-2 top-1/2 transform -translate-y-1/2 bg-gray-800 bg-opacity-75 hover:bg-opacity-100 text-white p-1 rounded-full hidden transition-all z-10">
                                                        <i data-feather="chevron-right" class="w-6 h-6"></i>
                                                    </button>
                                                    <div id="image-dots" class="flex justify-center items-center space-x-2 mt-2">
                                                        <!-- Dots will be injected here by JS -->
                                                    </div>
                                                </div>
                                                
                                                <div class="flex justify-between items-center mt-3">
                                                    <div class="flex items-center space-x-2">
                                                        <%= f.file_field :images, 
                                                            multiple: true,
                                                            accept: "image/*",
                                                            class: "hidden",
                                                            id: "post-image-upload" %>
                                                        <label for="post_images_input" class="p-2 text-gray-400 hover:text-blue-400 rounded-full hover:bg-gray-700 cursor-pointer" id="btn-upload-image">
                                                            <i data-feather="image" class="w-5 h-5"></i>
                                                        </label>
                                                    </div>
                                                    
                                                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg font-medium cursor-pointer flex items-center gap-2">
                                                        <i data-feather="send" class="w-4 h-4" style="display: inline-block; vertical-align: middle;"></i>
                                                        <span style="vertical-align: middle;">Publicar</span>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                    <% end %>
                                

                            </div>
                        <% end %>

                        <div id="posts_list" class="space-y-6">
                            <% if @posts.present? %>
                                <% @posts.each do |post| %>
                                    <% @post = post.id %>


                                    <%= turbo_frame_tag "post_#{post.id}", class: "post-card block" do %>
                                        <div class="bg-gray-800 rounded-xl p-6 shadow-lg relative" >
                                            <div class="absolute top-4 right-4 z-10">
                                                <% if !current_user.club? or (current_user.club? and current_user.club_profile.verified?) %>
                                                    <button class="post-options-btn p-2 text-gray-400 hover:text-white hover:bg-gray-700 rounded-full transition">
                                                        <i data-feather="more-vertical"></i>
                                                    </button>
                                                    <div class="post-options-dropdown hidden absolute right-0 mt-2 w-56 bg-gray-700 rounded-md shadow-lg z-10 border border-gray-600">
                                                        <% if post.user == current_user or current_user.admin? %>
                                                            <a data-modal-target="modal-apagar-post-<%= post.id %>" data-modal-toggle="modal-apagar-post-<%= post.id %>" class="save-post-btn block px-4 py-2 text-sm text-gray-200 hover:bg-gray-600 hover:text-red-700 rounded-t-md transition-colors clickable">
                                                                <div class="flex items-center"><i data-feather="trash-2" class="w-4 h-4 mr-2"></i><span class="save-text">Apagar publicação</span></div>
                                                            </a>
                                                        <% end %>
                                                        <%= render "posts/save_section", post: post %>
                                                    </div>
                                                <% end %>
                                            </div>

                                            <div class="clickable" data-modal-target="modal-post-<%=post.id%>" data-modal-toggle="modal-post-<%=post.id%>">
                                            <div class="flex items-center justify-between mb-4">
                                                <div class="flex items-center space-x-3">
                                                    <div class="w-10 h-10 rounded-full bg-gray-700 flex-shrink-0 overflow-hidden flex items-center justify-center">
                                                        <% if club_profile.profile_picture.attached? %>
                                                            <%= image_tag url_for(club_profile.profile_picture), class: "w-full h-full object-cover" %>
                                                        <% else %>
                                                            <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                                                        <% end %>
                                                    </div>
                                                <div>
                                                    <h3 class="font-bold text-white">
                                                    <% if post.user.club? %>
                                                        <%= link_to post.user.club_profile.name, club_profile_path(post.user.club_profile), 
                                                            data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                                    <% elsif post.user.player? %>
                                                        <%= link_to post.user.player_profile.name, player_profile_path(post.user.player_profile), 
                                                            data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                                    <% elsif post.user.coach? %>
                                                        <%= link_to post.user.coach_profile.name, coach_profile_path(post.user.coach_profile), 
                                                            data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                                    <% elsif post.user.board? %>
                                                        <%= link_to post.user.board_profile.name, board_profile_path(post.user.board_profile), 
                                                            data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                                    <% elsif post.user.user? %>
                                                        <%= link_to post.user.user_profile.name, user_profile_path(post.user.user_profile), 
                                                            data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                                    <% elsif post.user.admin? %>
                                                        <%= link_to post.user.admin_profile.name, admin_profile_path(post.user.admin_profile), 
                                                            data: { turbo_frame: "_top" }, class: "hover:underline" %>
                                                    <% end %>
                                                    </h3>
                                                    <span class="text-gray-400 text-sm">
                                                    <%= time_ago_in_words(post.created_at) %> atrás
                                                    </span>
                                                </div>
                                                </div>
                                            </div>
                                            
                                            <p class="text-gray-300 mb-4">
                                                <%= post.content %>
                                            </p>
                                            
                                            <% if post.images.attached? %>
                                                <div class="mb-4">
                                                    <% if post.images.count == 1 %>
                                                        <%= image_tag post.images.first, class: "w-full rounded-lg object-cover max-h-96" %>
                                                    <% else %>
                                                        <!-- Carrossel com múltiplas imagens -->
                                                        <div class="post-images-carousel relative rounded-lg overflow-hidden">
                                                            <div class="carousel-images flex transition-transform duration-300 ease-in-out">
                                                                <% post.images.each do |image| %>
                                                                    <div class="carousel-image w-full flex-shrink-0">
                                                                        <%= image_tag image, class: "w-full h-96 object-contain" %>
                                                                    </div>
                                                                <% end %>
                                                            </div>
                                                            
                                                            <!-- Botões de navegação -->
                                                            <button class="carousel-prev absolute left-2 top-1/2 transform -translate-y-1/2 bg-gray-800 bg-opacity-75 hover:bg-opacity-100 text-white p-2 rounded-full transition-all z-10">
                                                                <i data-feather="chevron-left" class="w-6 h-6"></i>
                                                            </button>
                                                            <button class="carousel-next absolute right-2 top-1/2 transform -translate-y-1/2 bg-gray-800 bg-opacity-75 hover:bg-opacity-100 text-white p-2 rounded-full transition-all z-10">
                                                                <i data-feather="chevron-right" class="w-6 h-6"></i>
                                                            </button>
                                                            
                                                            <!-- Dots indicadores -->
                                                            <div class="absolute bottom-4 left-1/2 transform -translate-x-1/2 flex space-x-2">
                                                                <% post.images.count.times do |i| %>
                                                                    <button class="carousel-dot w-2 h-2 rounded-full bg-gray-600 transition-colors cursor-pointer"></button>
                                                                <% end %>
                                                            </div>
                                                        </div>
                                                    <% end %>
                                                </div>
                                            
                                            <% end %>
                                            </div>    

                                            <div class="flex items-center pt-4 border-t border-gray-700">
                                                
                                                <% if !current_user.club? or (current_user.club? and current_user.club_profile.verified?) %>
                                                <%= render "posts/like_section", post: post %>

                                                <div data-modal-target="modal-post-<%=post.id%>" data-modal-toggle="modal-post-<%=post.id%>" class="px-4">
                                                    <%= render "posts/comments_count", post: post %>
                                                </div>
                                                <% end %>
                                            </div>
                                        </div>


                                    <% end %>

                                    <!-- Modal confirmação apagar publicação -->

                                            <div id="modal-apagar-post-<%= post.id %>" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black bg-opacity-50">
                                                <div class="bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4 shadow-2xl border border-gray-700 transform transition-all">
                                                    <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-red-900 rounded-full">
                                                        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                                                        </svg>
                                                    </div>
                                                    <h3 class="text-xl font-semibold text-white text-center mb-2">Confirmar ação</h3>
                                                    <p class="text-gray-300 text-center mb-6"> Tem a certeza que pretende apagar esta publicação? Esta ação é irreversível! </b>  </p>
                                                    <div class="flex gap-3">
                                                        <button data-modal-hide="modal-apagar-post-<%= post.id %>" class="flex-1 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium">
                                                            Cancelar
                                                        </button>
                                                        <%= button_to post_path(post), method: :delete, 
                                                            onclick: "document.body.style.overflow=''",
                                                            data: { turbo_frame: "_top", modal_hide: "modal-apagar-post-#{post.id}" },
                                                            class: "flex-1 px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition-colors font-medium" do %>
                                                            Apagar Publicação
                                                        <% end %>
                                                    </div>
                                                </div>
                                            </div>

                                    <!-- Full Screen Comment Modal -->
                                        <div id="modal-post-<%=post.id%>" class="fixed inset-0 z-[100] bg-black bg-opacity-50 hidden  ">
                                            <div class="flex flex-col lg:flex-row w-full h-full">
                                                <!-- Left: Post Content (Visible on Desktop) -->
                                                <div class="hidden lg:flex lg:w-2/3 h-full bg-transparent bg-opacity-50 items-center justify-center p-8 overflow-y-auto relative">
                                                    <div id="modal-post-container" class="w-full bg-gray-800 rounded-xl p-6 shadow-2xl flex flex-col" style="max-width: 800px; max-height: 90vh;">
                                                            <div class="flex items-center justify-between mb-4">
                                                                <div class="flex items-center space-x-3">
                                                                    <div class="w-10 h-10 rounded-full bg-gray-700 flex-shrink-0 overflow-hidden flex items-center justify-center">
                                                                        <% if club_profile.profile_picture.attached? %>
                                                                            <%= image_tag url_for(club_profile.profile_picture), class: "w-full h-full object-cover", id: "profile-pic-img" %>
                                                                        <% else %>
                                                                            <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover", id: "profile-pic-img" %>
                                                                        <% end %>
                                                                    </div>
                                                                    <div>
                                                                        <h3 class="font-bold text-white">
                                                                            <% if post.user.club? %>
                                                                                <%= link_to club_profile_path(post.user.club_profile), 
                                                                                    data: { turbo_frame: "_top" }, 
                                                                                    class: "hover:underline" do %>
                                                                                    <%= post.user.club_profile.name %>
                                                                                <% end %>
                                                                            <% elsif post.user.player? %>
                                                                                <%= link_to player_profile_path(post.user.player_profile), 
                                                                                    data: { turbo_frame: "_top" }, 
                                                                                    class: "hover:underline" do %>
                                                                                    <%= post.user.player_profile.name %>
                                                                                <% end %>
                                                                            <% elsif post.user.coach? %>
                                                                                <%= link_to coach_profile_path(post.user.coach_profile), 
                                                                                    data: { turbo_frame: "_top" }, 
                                                                                    class: "hover:underline" do %>
                                                                                    <%= post.user.coach_profile.name %>
                                                                                <% end %>
                                                                            <% elsif post.user.board? %>
                                                                                <%= link_to board_profile_path(post.user.board_profile), 
                                                                                    data: { turbo_frame: "_top" }, 
                                                                                    class: "hover:underline" do %>
                                                                                    <%= post.user.board_profile.name %>
                                                                                <% end %>
                                                                            <% elsif post.user.user? %>
                                                                                <%= link_to user_profile_path(post.user.user_profile), 
                                                                                    data: { turbo_frame: "_top" }, 
                                                                                    class: "hover:underline" do %>
                                                                                    <%= post.user.user_profile.name %>
                                                                                <% end %>
                                                                            <% elsif post.user.admin? %>
                                                                                <%= link_to admin_profile_path(post.user.admin_profile), 
                                                                                    data: { turbo_frame: "_top" }, 
                                                                                    class: "hover:underline" do %>
                                                                                    <%= post.user.admin_profile.name %>
                                                                                <% end %>
                                                                            <% end %>
                                                                        </h3>
                                                                        <span class="text-gray-400 text-sm">
                                                                            <%= time_ago_in_words(post.created_at) %> atrás
                                                                        </span>
                                                                    </div>
                                                                </div>
                                                                
                                                                <div class="relative">
                                                                    <% if !current_user.club? or (current_user.club? and current_user.club_profile.verified?) %>
