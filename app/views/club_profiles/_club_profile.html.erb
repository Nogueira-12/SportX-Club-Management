    <script>
        // Inicializa os ícones da biblioteca Feather (substitui as tags <i> pelos ícones SVG)
        feather.replace();

        // --- Lógica do Modal de Imagem (Visualizar foto de perfil em ecrã inteiro) ---
        
        // Encontra o contentor da foto de perfil pequena
        const profilePicContainer = document.getElementById('profile-pic-container');
        // Encontra o modal (janela flutuante) que vai mostrar a imagem grande
        const imageModal = document.getElementById('image-modal');
        // Encontra o elemento de imagem dentro do modal
        const modalImage = document.getElementById('modal-image');
        // Encontra o botão de fechar o modal
        const closeImageModalBtn = document.getElementById('close-image-modal');

        // Verifica se todos os elementos existem na página antes de adicionar eventos
        if (profilePicContainer && imageModal && modalImage && closeImageModalBtn) {
            // Quando se clica na foto de perfil pequena
            profilePicContainer.addEventListener('click', () => {
                // Encontra a imagem real dentro do contentor
                const profilePicImg = document.getElementById('profile-pic-img');
                // Se a imagem existir
                if (profilePicImg) {
                    // Copia o endereço da imagem pequena para a imagem grande do modal
                    modalImage.src = profilePicImg.src;
                    // Remove a classe que esconde o modal
                    imageModal.classList.remove('hidden');
                    // Adiciona a classe para centrar o conteúdo (flex)
                    imageModal.classList.add('flex');
                    // Impede que a página por trás faça scroll
                    document.body.style.overflow = 'hidden';
                }
            });

            // Função para fechar o modal
            const closeModal = () => {
                // Esconde o modal novamente
                imageModal.classList.add('hidden');
                // Remove a formatação de flex
                imageModal.classList.remove('flex');
                // Permite que a página volte a fazer scroll
                document.body.style.overflow = '';
            };

            // Quando se clica no botão de fechar, executa a função de fechar
            closeImageModalBtn.addEventListener('click', closeModal);
            
            // Quando se clica na área escura à volta da imagem, também fecha
            imageModal.addEventListener('click', (e) => {
                // Verifica se o clique foi exatamente no fundo escuro e não na imagem
                if (e.target === imageModal) closeModal();
            });

            // Gestão dos dropdowns dos 3 pontos
                document.body.addEventListener('click', (e) => {
                    const target = e.target;
                    
                    const optionsBtn = target.closest('.post-options-btn');
                    if (optionsBtn) {
                        e.stopPropagation();
                        document.querySelectorAll('.post-options-dropdown').forEach(d => {
                            if (d !== optionsBtn.nextElementSibling) d.classList.add('hidden');
                        });
                        optionsBtn.nextElementSibling.classList.toggle('hidden');
                        return;
                    }
                    
                    if (!target.closest('.post-options-dropdown')) {
                        document.querySelectorAll('.post-options-dropdown').forEach(d => d.classList.add('hidden'));
                    }
                });

                document.addEventListener('turbo:frame-load', () => {
                    if (typeof feather !== 'undefined') feather.replace();
                    initializeCarousels();
                    
                    // ADICIONA ESTA LINHA:
                    if (typeof initFlowbite !== 'undefined') initFlowbite();
                });

                // ADICIONA TAMBÉM ESTE EVENTO NOVO (para Turbo Stream updates):
                document.addEventListener('turbo:before-stream-render', (event) => {
                    // Depois do Turbo Stream renderizar, re-inicializa o Flowbite
                    setTimeout(() => {
                        if (typeof initFlowbite !== 'undefined') initFlowbite();
                        if (typeof feather !== 'undefined') feather.replace();
                    }, 50);
                });
        }

    </script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        
        body {
            font-family: 'Inter', sans-serif;
            transition: all 0.3s ease;
        }
        
        .profile-pic {
            border: 4px solid #1e293b;
            transition: transform 0.3s ease;
        }
        
        .profile-pic:hover {
            transform: scale(1.05);
        }
        
        .post-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        
        .post-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
        }
        
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Thin Scrollbar for Emoji Picker */
        .thin-scrollbar::-webkit-scrollbar {
            height: 2px;
        }
        .thin-scrollbar::-webkit-scrollbar-track {
            background: transparent;
        }
        .thin-scrollbar::-webkit-scrollbar-thumb {
            background-color: #4b5563;
            border-radius: 20px;
        }

        #modal-image-container #close-image-modal {
            position: absolute;
            top: 1rem;
            right: 1rem;
            background-color: rgba(41, 41, 51, 0.5); /* cinza quase transparente */
            color: white;
            border-radius: 9999px; /* rounded-full */
            padding: 0.5rem; /* p-2 */
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease, background-color 0.3s ease, visibility 0.3s ease;
        }

        #modal-image-container:hover #close-image-modal {
            opacity: 1;
            visibility: visible;
        }

        #modal-image-container #close-image-modal:hover {
            background-color: #ef4444; /* red-500 */
        }
    </style>

