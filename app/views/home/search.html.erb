<body class="bg-gray-900 text-gray-100 min-h-screen">

  <%# ========== NAVBAR (from index.html.erb) ========== %>
  <nav class="bg-gray-800 py-4 px-6 shadow-lg fixed w-full z-30 top-0 start-0" style="--nav-height:64px;">
    <div class="container mx-auto flex items-center justify-between flex-wrap">

      <div class="flex items-center space-x-6">
        <div class="flex items-center">
          <% if user_signed_in? %>
            <div class="w-8 h-8 rounded-md flex items-center justify-center">
              <a href="<%= root_path %>"><%= image_tag "logo_sem_texto.png", alt: "Logo", class: "rounded-full" %></a>
            </div>
          <% else %>
            <div class="w-8 h-8 rounded-md flex items-center justify-center">
              <a href="<%= root_path %>><%= image_tag "logo_sem_texto.png", alt: "Logo", class: "rounded-full" %></a>
            </div>
          <% end %>
          <span class="ml-2 font-bold text-xl">SportX</span>
        </div>
      </div>



      <div class="flex items-center space-x-4">


        <div class="relative" id="user-menu-container">
          <% if user_signed_in? %>
            <button type="button" class="border border-gray-900 flex text-sm rounded-full hover:ring-4 focus:ring-gray-300 dark:focus:ring-gray-600 w-9 h-9 bg-gray-700 items-center justify-center overflow-hidden" id="user-menu-button">
              <%
                current_profile = nil
                if current_user.club?
                  current_profile = current_user.club_profile
                elsif current_user.player?
                  current_profile = current_user.player_profile
                elsif current_user.board?
                  current_profile = current_user.board_profile
                elsif current_user.coach?
                  current_profile = current_user.coach_profile
                elsif current_user.admin?
                  current_profile = current_user.admin_profile
                elsif current_user.user?
                  current_profile = current_user.user_profile
                end
              %>
              <% if current_profile&.profile_picture&.attached? %>
                <%= image_tag url_for(current_profile.profile_picture), class: "w-full h-full object-cover" %>
              <% else %>
                <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
              <% end %>
            </button>
            <div class="absolute right-0 mt-2 z-50 hidden w-56 text-base list-none bg-white divide-y divide-gray-100 rounded-lg shadow-sm dark:bg-gray-700 dark:divide-gray-600" id="user-dropdown">
              <div class="px-4 py-3">
                <% if current_user.club? %>
                  <span class="block text-sm text-gray-900 dark:text-white"><%= current_user.club_profile.name %></span>
                <% elsif current_user.board? %>
                  <span class="block text-sm text-gray-900 dark:text-white"><%= current_user.board_profile.name %></span>
                <% elsif current_user.coach? %>
                  <span class="block text-sm text-gray-900 dark:text-white"><%= current_user.coach_profile.name %></span>
                <% elsif current_user.player? %>
                  <span class="block text-sm text-gray-900 dark:text-white"><%= current_user.player_profile.name %></span>
                <% elsif current_user.admin? %>
                  <span class="block text-sm text-gray-900 dark:text-white"><%= current_user.admin_profile.name %></span>
                <% elsif current_user.user? %>
                  <span class="block text-sm text-gray-900 dark:text-white"><%= current_user.user_profile.name %></span>
                <% end %>
                <span class="block text-sm text-gray-500 truncate dark:text-gray-400"><%= current_user.email %></span>
              </div>
              <ul class="py-2">
                <li>
                  <% if current_user.club? %>
                    <%= link_to club_profile_path(ClubProfile.find(current_user.club_profile.id)), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400" do %>
                      <i data-feather="user" class="mr-2"></i>Perfil
                    <% end %>
                  <% elsif current_user.player? %>
                    <%= link_to player_profile_path(PlayerProfile.find(current_user.player_profile.id)), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400" do %>
                      <i data-feather="user" class="mr-2"></i>Perfil
                    <% end %>
                  <% elsif current_user.board? %>
                    <%= link_to board_profile_path(BoardProfile.find(current_user.board_profile.id)), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400" do %>
                      <i data-feather="user" class="mr-2"></i>Perfil
                    <% end %>
                  <% elsif current_user.coach? %>
                    <%= link_to coach_profile_path(CoachProfile.find(current_user.coach_profile.id)), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400" do %>
                      <i data-feather="user" class="mr-2"></i>Perfil
                    <% end %>
                  <% elsif current_user.admin? %>
                    <%= link_to admin_profile_path(AdminProfile.find(current_user.admin_profile.id)), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400" do %>
                      <i data-feather="user" class="mr-2"></i>Perfil
                    <% end %>
                  <% elsif current_user.user? %>
                    <%= link_to user_profile_path(UserProfile.find(current_user.user_profile.id)), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400" do %>
                      <i data-feather="user" class="mr-2"></i>Perfil
                    <% end %>
                  <% end %>
                </li>
                <li>
                                    <% if current_user.club? %>
                                        <% @club_obj = ClubProfile.find(current_user.club_profile.id) %>
                                        <%= link_to edit_club_profile_path(@club_obj), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 active:bg-gray-100 dark:hover:bg-gray-600 dark:active:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400 dark:active:text-blue-400" do %>
                                            <i data-feather="settings" class="mr-2"></i>
                                            <span>Definições</span>
                                        <% end %>
                                    <% elsif current_user.player? %>
                                        <% @player_obj = PlayerProfile.find(current_user.player_profile.id) %>
                                        <%= link_to edit_player_profile_path(@player_obj), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 active:bg-gray-100 dark:hover:bg-gray-600 dark:active:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400 dark:active:text-blue-400" do %>
                                            <i data-feather="settings" class="mr-2"></i>
                                            <span>Definições</span>
                                        <% end %>
                                    <% elsif current_user.board? %>
                                        <% @board_obj = BoardProfile.find(current_user.board_profile.id) %>
                                            <%= link_to edit_board_profile_path(@board_obj), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 active:bg-gray-100 dark:hover:bg-gray-600 dark:active:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400 dark:active:text-blue-400" do %>
                                                <i data-feather="settings" class="mr-2"></i>
                                                <span>Definições</span>
                                            <% end %>
                                    <% elsif current_user.coach? %>
                                        <% @coach_obj = CoachProfile&.find(current_user.coach_profile.id) %>
                                        <%= link_to edit_coach_profile_path(@coach_obj), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 active:bg-gray-100 dark:hover:bg-gray-600 dark:active:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400 dark:active:text-blue-400" do %>
                                            <i data-feather="settings" class="mr-2"></i>
                                            <span>Definições</span>
                                        <% end %>
                                    <% elsif current_user.admin? %>
                                        <% @admin_obj = AdminProfile.find(current_user.admin_profile.id) %>
                                        <%= link_to edit_admin_profile_path(@admin_obj), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 active:bg-gray-100 dark:hover:bg-gray-600 dark:active:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400 dark:active:text-blue-400" do %>
                                            <i data-feather="settings" class="mr-2"></i>
                                            <span>Definições</span>
                                        <% end %>
                                    <% elsif current_user.user? %>
                                        <% @user_obj = UserProfile.find(current_user.user_profile.id) %>
                                        <%= link_to edit_user_profile_path(@user_obj), class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 active:bg-gray-100 dark:hover:bg-gray-600 dark:active:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400 dark:active:text-blue-400" do %>
                                            <i data-feather="settings" class="mr-2"></i>
                                            <span>Definições</span>
                                        <% end %>
                                    <% end%>
                                </li>
                <li>
                  <%= button_to destroy_user_session_path, method: :delete, form_class: "w-full", class: "w-full text-left flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-red-500" do %>
                    <i data-feather="log-out" class="mr-2"></i>Log out
                  <% end %>
                </li>
              </ul>
            </div>
          <% else %>
            <button type="button" class="border border-gray-900 flex text-sm rounded-full hover:ring-4 focus:ring-gray-300 dark:focus:ring-gray-600 w-9 h-9 bg-gray-700 items-center justify-center" id="user-menu-button">
              <i data-feather="user"></i>
            </button>
            <div class="absolute right-0 mt-2 z-50 hidden w-48 text-base list-none bg-white divide-y divide-gray-100 rounded-lg shadow-sm dark:bg-gray-700 dark:divide-gray-600 md:w-56" id="user-dropdown">
              <ul class="py-2">
                <li>
                  <%= link_to new_user_session_path, class: "flex items-center px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-blue-400" do %>
                    <i data-feather="log-in" class="mr-2"></i><span>Login</span>
                  <% end %>
                </li>
              </ul>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </nav>

  <%# ========== MAIN CONTENT ========== %>
  <main class="container mx-auto px-4 pt-24 pb-10">

    <%
      selected_category = params[:category].presence || 'perfis'
      selected_label    = selected_category == 'publicacoes' ? 'Publicações' : 'Perfis'
    %>

    <%# ---- Search bar + filter row ---- %>
    <div class="flex flex-col md:flex-row justify-between items-center gap-3 mb-4">

      <%# Filter dropdown %>
      <div class="flex items-center gap-2">
        <span class="text-sm text-gray-300 hidden md:inline">Filtrar por:</span>
        <div class="relative">
          <button id="search-category-button"
                  class="inline-flex items-center justify-between gap-2 rounded-xl border border-gray-600 bg-gray-800 px-3 py-2 text-sm font-medium text-white hover:border-yellow-500"
                  type="button">
            <i data-feather="filter" class="w-4 h-4"></i>
            <span class="font-semibold"><%= selected_label %></span>
            <i data-feather="chevron-down" class="w-3 h-3"></i>
          </button>
          <div id="search-category-menu"
               class="hidden absolute left-0 mt-2 w-44 rounded-xl border border-gray-700 bg-gray-800 shadow-xl z-20">
            <%= link_to "Perfis",
                  "#{request.path}?#{request.query_parameters.merge(category: 'perfis').to_query}",
                  class: "block px-4 py-2 text-sm text-white hover:bg-gray-700" %>
            <%= link_to "Publicações",
                  "#{request.path}?#{request.query_parameters.merge(category: 'publicacoes').to_query}",
                  class: "block px-4 py-2 text-sm text-white hover:bg-gray-700" %>
          </div>
        </div>
      </div>

      <%# Search input %>
      <div class="flex-1 md:flex-none w-full md:w-auto">
        <%= form_tag home_search_path, method: :get, class: "flex justify-end" do %>
          <%= hidden_field_tag :category, selected_category %>
          <%= text_field_tag :query, params[:query],
                placeholder: "Pesquisar...",
                class: "w-full md:w-96 bg-gray-700 border border-gray-600 rounded-full px-3 py-2 text-sm text-white placeholder-gray-300 focus:outline-none focus:ring-1 focus:ring-blue-500 focus:border-blue-500 transition duration-200" %>
          <button type="submit"
                  class="ml-2 bg-blue-600 hover:bg-blue-500 text-white px-3 py-2 rounded-full font-semibold transition duration-200">
            <i data-feather="search" class="w-5 h-5"></i>
          </button>
        <% end %>
      </div>
    </div>

    <%# ---- Page heading ---- %>
    <div class="mb-6">
      <h1 class="text-2xl md:text-3xl font-bold text-white mt-4 mb-2">
        Resultados para "<%= params[:query].to_s.truncate(80) %>"
      </h1>
      <p class="text-gray-400 text-sm">
        A mostrar <%= selected_label.downcase %> correspondentes à pesquisa
      </p>
    </div>

    <%# ================================================================ %>
    <%# ========================== PUBLICAÇÕES ========================= %>
    <%# ================================================================ %>
    <% if selected_category == 'publicacoes' %>

      <% author_posts  = @author_posts  || [] %>
      <% content_posts = @content_posts || [] %>
      <% all_posts     = (author_posts + content_posts).uniq(&:id) %>

      <% if all_posts.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <% all_posts.each do |post| %>
            <%= render "search/post_card", post: post %>
          <% end %>
        </div>
      <% else %>
        <div class="bg-gray-800 border border-gray-700 rounded-2xl p-10 text-center text-gray-400">
          <i data-feather="inbox" class="w-12 h-12 mx-auto mb-3 text-gray-600"></i>
          <p class="text-lg font-medium">Nenhuma publicação encontrada para esta pesquisa.</p>
        </div>
      <% end %>

    <% else %>

    <%# ================================================================ %>
    <%# ========================== Perfis ============================== %>
    <%# ================================================================ %>
      <% profiles = @profile_results || @profiles || [] %>

      <% if profiles.any? %>
        <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          <% profiles.each do |profile| %>

            <%
              profile_name = profile.try(:name) || profile.try(:full_name) || "Perfil"

              profile_type_label =
                if profile.is_a?(ClubProfile)    then "Clube"
                elsif profile.is_a?(PlayerProfile) then "Jogador"
                elsif profile.is_a?(CoachProfile)  then profile.try(:coach_type).presence || "Treinador"
                elsif profile.is_a?(BoardProfile)  then "Direção"
                elsif profile.is_a?(UserProfile)   then "Utilizador"
                else "Perfil"
                end



              profile_url =
                if profile.is_a?(ClubProfile)    then club_profile_path(profile)
                elsif profile.is_a?(PlayerProfile) then player_profile_path(profile)
                elsif profile.is_a?(CoachProfile)  then coach_profile_path(profile)
                elsif profile.is_a?(BoardProfile)  then board_profile_path(profile)
                elsif profile.is_a?(UserProfile)   then user_profile_path(profile)
                else "#"
                end
            %>

            <%= link_to profile_url,
                  class: "group block bg-gray-800 border border-gray-700 rounded-xl overflow-hidden hover:border-yellow-500 hover:shadow-xl transition-all duration-200" do %>

              <div class="relative h-24 bg-gradient-to-r from-gray-700 to-gray-800">
                <% if profile.respond_to?(:banner_picture) && profile.banner_picture.attached? %>
                  <%= image_tag url_for(profile.banner_picture), class: "w-full h-full object-cover" %>
                <% else %>
                  <div class="w-full h-full" style="background: linear-gradient(135deg, #1e3a5f 0%, #1a2940 100%);"></div>
                <% end %>

                <div class="absolute -bottom-8 left-4 w-16 h-16 rounded-full border-4 border-gray-800 bg-gray-700 overflow-hidden shadow-lg">
                  <% if profile.respond_to?(:profile_picture) && profile.profile_picture.attached? %>
                    <%= image_tag url_for(profile.profile_picture), class: "w-full h-full object-cover" %>
                  <% else %>
                    <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
                  <% end %>
                </div>

              </div>

              <div class="px-4 pb-4 pt-10">
                <p class="text-base font-bold text-white truncate"><%= profile_name %></p>

                <% if profile.respond_to?(:bio) && profile.bio.present? %>
                  <p class="text-gray-200 text-xs mt-2 line-clamp-2"><%= profile.bio %></p>
                <% end %>
              </div>
            <% end %>
          <% end %>
        </div>

      <% else %>
        <div class="col-span-3 bg-gray-800 border border-gray-700 rounded-2xl p-10 text-center text-gray-400">
          <i data-feather="users" class="w-12 h-12 mx-auto mb-3 text-gray-600"></i>
          <p class="text-lg font-medium">Nenhum perfil encontrado para esta pesquisa.</p>
        </div>
      <% end %>

    <% end %>
  </main>

  <script>
    document.addEventListener('DOMContentLoaded', () => {

      // ── Feather icons ──
      if (window.feather) feather.replace();

      // ── Filter dropdown ──
      const filterBtn  = document.getElementById('search-category-button');
      const filterMenu = document.getElementById('search-category-menu');
      if (filterBtn && filterMenu) {
        filterBtn.addEventListener('click', () => filterMenu.classList.toggle('hidden'));
        document.addEventListener('click', (e) => {
          if (!filterBtn.contains(e.target) && !filterMenu.contains(e.target))
            filterMenu.classList.add('hidden');
        });
      }

      // ── User dropdown ──
      const userMenuBtn  = document.getElementById('user-menu-button');
      const userDropdown = document.getElementById('user-dropdown');
      let pinned = false;
      if (userMenuBtn && userDropdown) {
        document.getElementById('user-menu-container').addEventListener('mouseenter', () => userDropdown.classList.remove('hidden'));
        document.getElementById('user-menu-container').addEventListener('mouseleave', () => { if (!pinned) userDropdown.classList.add('hidden'); });
        userMenuBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          pinned = !pinned;
          if (pinned) userDropdown.classList.remove('hidden');
        });
        document.addEventListener('click', () => { if (pinned) { pinned = false; userDropdown.classList.add('hidden'); } });
      }

      // ══════════════════════════════════════════════════════
      // SEARCH POST MODALS
      // ══════════════════════════════════════════════════════

      // Stack-based modal manager (same pattern as main feed)
      const openModals = [];

      function cleanupSearchModalState() {
        document.querySelectorAll('[data-search-modal="true"]').forEach((modal) => {
          if (modal.classList.contains('hidden')) {
            modal.style.zIndex = '';
          }
        });

        const visibleSearchModals = Array.from(document.querySelectorAll('[data-search-modal="true"]'))
          .filter((modal) => !modal.classList.contains('hidden'));

        openModals.length = 0;
        visibleSearchModals.forEach((modal) => openModals.push(modal));

        if (openModals.length === 0) {
          document.querySelectorAll('[modal-backdrop], .modal-backdrop').forEach((backdrop) => backdrop.remove());
        }

        document.body.style.overflow = openModals.length > 0 ? 'hidden' : '';
      }

      function openSearchModal(modalEl) {
        if (!modalEl || !modalEl.classList.contains('hidden')) return;
        modalEl.style.zIndex = 100 + openModals.length * 10;
        modalEl.classList.remove('hidden');
        openModals.push(modalEl);
        document.body.style.overflow = 'hidden';
        // Init carousel inside newly opened modal
        initSearchCarousels(modalEl);
        if (window.feather) feather.replace();
      }

      function closeSearchModal(modalEl) {
        if (!modalEl) return;
        modalEl.classList.add('hidden');
        modalEl.style.zIndex = '';
        const idx = openModals.indexOf(modalEl);
        if (idx > -1) openModals.splice(idx, 1);
        cleanupSearchModalState();
      }

      // ── Flowbite-compatible data-modal-toggle / data-modal-hide ──
      // (Flowbite is loaded globally; this ensures our search modals also work with it.
      //  We add a delegated listener as a fallback for any element using our custom classes.)
      document.body.addEventListener('click', (e) => {
        // Open search post modal via custom trigger
        const toggleEl = e.target.closest('.search-open-modal-trigger');
        if (toggleEl) {
          e.stopPropagation();
          const targetId = toggleEl.dataset.searchModalId;
          const modal = targetId ? document.getElementById(targetId) : null;
          if (modal) openSearchModal(modal);
          return;
        }

        // Open delete confirmation modal via custom trigger
        const deleteToggleEl = e.target.closest('.search-open-delete-modal-trigger');
        if (deleteToggleEl) {
          e.stopPropagation();
          const targetId = deleteToggleEl.dataset.searchDeleteModalId;
          const modal = targetId ? document.getElementById(targetId) : null;
          if (modal) openSearchModal(modal);
          return;
        }

        // Close via our custom close button
        const closeBtn = e.target.closest('.search-close-modal-btn');
        if (closeBtn) {
          e.stopPropagation();
          const modalId = closeBtn.dataset.modalId;
          const modal = modalId ? document.getElementById(modalId) : closeBtn.closest('[id^="search-post-modal-"]');
          if (modal) closeSearchModal(modal);
          return;
        }

        // Close via data-modal-hide on delete confirmation modals
        const hideEl = e.target.closest('[data-modal-hide^="search-modal-apagar-"]');
        if (hideEl) {
          const modal = document.getElementById(hideEl.dataset.modalHide);
          if (modal) closeSearchModal(modal);
          return;
        }

        // Click on backdrop (the dark overlay itself) closes the topmost modal
        if (openModals.length > 0) {
          const topModal = openModals[openModals.length - 1];
          // Check: user clicked directly on the backdrop (not its children)
          if (e.target === topModal) {
            closeSearchModal(topModal);
          }
        }
      });

      // ── Options dropdown (three-dot menu) inside search modals ──
      document.body.addEventListener('click', (e) => {
        const optBtn = e.target.closest('.search-post-options-btn');
        if (optBtn) {
          e.stopPropagation();
          document.querySelectorAll('.search-post-options-dropdown').forEach(d => {
            if (d !== optBtn.nextElementSibling) d.classList.add('hidden');
          });
          optBtn.nextElementSibling.classList.toggle('hidden');
          return;
        }
        // Close options dropdown on outside click
        if (!e.target.closest('.search-post-options-dropdown')) {
          document.querySelectorAll('.search-post-options-dropdown').forEach(d => d.classList.add('hidden'));
        }
      });

      // ══════════════════════════════════════════════════════
      // IMAGE CAROUSEL inside search post modals
      // ══════════════════════════════════════════════════════

      function initSearchCarousels(scope) {
        const root = scope || document;
        root.querySelectorAll('.search-post-carousel').forEach(carousel => {
          // Avoid double-init
          if (carousel.dataset.searchCarouselInit === 'true') return;
          carousel.dataset.searchCarouselInit = 'true';

          const track  = carousel.querySelector('.search-carousel-track');
          const slides = carousel.querySelectorAll('.search-carousel-slide');
          const dots   = carousel.querySelectorAll('.search-carousel-dot');
          const prev   = carousel.querySelector('.search-carousel-prev');
          const next   = carousel.querySelector('.search-carousel-next');

          if (!track || slides.length <= 1) return;

          let current = 0;

          function update() {
            track.style.transform = `translateX(-${current * 100}%)`;
            dots.forEach((d, i) => {
              d.classList.toggle('bg-blue-500', i === current);
              d.classList.toggle('bg-gray-600', i !== current);
            });
            if (prev) {
              prev.disabled = current === 0;
              prev.classList.toggle('opacity-50', current === 0);
            }
            if (next) {
              next.disabled = current === slides.length - 1;
              next.classList.toggle('opacity-50', current === slides.length - 1);
            }
          }

          if (prev) {
            prev.addEventListener('click', (e) => {
              e.stopPropagation();
              if (current > 0) { current--; update(); }
            });
          }
          if (next) {
            next.addEventListener('click', (e) => {
              e.stopPropagation();
              if (current < slides.length - 1) { current++; update(); }
            });
          }
          dots.forEach((dot, i) => {
            dot.addEventListener('click', (e) => {
              e.stopPropagation();
              current = i;
              update();
            });
          });

          update();
        });
      }

      // Init any carousels already in the DOM (shouldn't be many since modals start hidden)
      initSearchCarousels(document);

      // Re-init after Turbo Stream / Frame updates
      document.addEventListener('turbo:frame-load', () => {
        if (window.feather) feather.replace();
        initSearchCarousels(document);
        cleanupSearchModalState();
      });
      document.addEventListener('turbo:before-stream-render', () => {
        setTimeout(() => {
          if (window.feather) feather.replace();
          initSearchCarousels(document);
          cleanupSearchModalState();
        }, 50);
      });
      document.addEventListener('turbo:load', cleanupSearchModalState);

      cleanupSearchModalState();

    }); // end DOMContentLoaded
  </script>

</body>
