<%= form_with(model: report_profile, class: "contents") do |form| %>
  <% if report_profile.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(report_profile.errors.count, "error") %> prohibited this report_profile from being saved:</h2>

      <ul class="list-disc ml-6">
        <% report_profile.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :users_id %>
    <%= form.text_field :users_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": report_profile.errors[:users_id].none?, "border-red-400 focus:outline-red-600": report_profile.errors[:users_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :content %>
    <%= form.textarea :content, rows: 4, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": report_profile.errors[:content].none?, "border-red-400 focus:outline-red-600": report_profile.errors[:content].any?}] %>
  </div>

  <div class="my-5 flex items-center gap-2">
    <%= form.label :resolved %>
    <%= form.checkbox :resolved, class: ["block shadow-sm rounded-md border order-first h-5 w-5", {"border-gray-400 focus:outline-blue-600": report_profile.errors[:resolved].none?, "border-red-400 focus:outline-red-600": report_profile.errors[:resolved].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
