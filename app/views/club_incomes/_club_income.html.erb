<div id="<%= dom_id club_income %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Club profile:</strong>
    <%= club_income.club_profile_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Value:</strong>
    <%= club_income.value %>
