<%= form_with(model: club_expense, class: "contents") do |form| %>
  <% if club_expense.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-md mt-3">
      <h2><%= pluralize(club_expense.errors.count, "error") %> prohibited this club_expense from being saved:</h2>

      <ul class="list-disc ml-6">
        <% club_expense.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
    <%= form.label :club_profile_id %>
    <%= form.text_field :club_profile_id, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": club_expense.errors[:club_profile_id].none?, "border-red-400 focus:outline-red-600": club_expense.errors[:club_profile_id].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :value %>
    <%= form.text_field :value, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": club_expense.errors[:value].none?, "border-red-400 focus:outline-red-600": club_expense.errors[:value].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :description %>
    <%= form.text_field :description, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": club_expense.errors[:description].none?, "border-red-400 focus:outline-red-600": club_expense.errors[:description].any?}] %>
  </div>

  <div class="my-5">
    <%= form.label :date %>
    <%= form.date_field :date, class: ["block shadow-sm rounded-md border px-3 py-2 mt-2 w-full", {"border-gray-400 focus:outline-blue-600": club_expense.errors[:date].none?, "border-red-400 focus:outline-red-600": club_expense.errors[:date].any?}] %>
  </div>

  <div class="inline">
    <%= form.submit class: "w-full sm:w-auto rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white inline-block font-medium cursor-pointer" %>
  </div>
<% end %>
