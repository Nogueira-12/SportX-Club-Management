<div id="<%= dom_id club_expense %>" class="w-full sm:w-auto my-5 space-y-5">
  <div>
    <strong class="block font-medium mb-1">Club profile:</strong>
    <%= club_expense.club_profile_id %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Value:</strong>
    <%= club_expense.value %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Description:</strong>
    <%= club_expense.description %>
  </div>
  <div>
    <strong class="block font-medium mb-1">Date:</strong>
    <%= club_expense.date %>
  </div>
</div>
