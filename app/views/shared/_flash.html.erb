<div id="flash">
  <% if flash.any? %>
    <div class="fixed top-4 right-4 z-[150] space-y-3 transition-opacity duration-500"
        id="flash-container">

      <% flash.to_h.except("banned").each do |type, message| %>

        <% case type
          when 'alert'
            bg_color = 'bg-red-600'
            icon = 'M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
          when 'notice'
            bg_color = 'bg-green-600'
            icon = 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'
          else
            bg_color = 'bg-blue-600'
            icon = 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
          end %>

        <div class="flex items-start gap-3 p-4 rounded-lg shadow-lg <%= bg_color %> text-white max-w-sm">
          
          <svg xmlns="http://www.w3.org/2000/svg"
              class="h-5 w-5 flex-shrink-0 mt-0.5"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor">
            <path stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="<%= icon %>" />
          </svg>

          <div class="flex-1">
            <p class="font-medium text-white">
              <%= message %>
            </p>
          </div>

          <button type="button"
                  class="text-white/60 hover:text-white transition"
                  onclick="this.closest('#flash-container').remove()">
            ✕
          </button>

        </div>

      <% end %>
    </div>

    <script>
      // Espera 3 segundos (3000 milissegundos)
      setTimeout(() => {

        // Vai buscar o container do flash
        const flash = document.getElementById("flash-container");

        // Se existir (segurança para evitar erros)
        if (flash) {

          // Aplica opacidade 0 (fade out suave)
          flash.style.opacity = "0";

          // Espera 500ms para a animação terminar
          setTimeout(() => {

            // Remove completamente do DOM
            flash.remove();

          }, 300);
        }

      }, 3000); // 5000ms = 5 segundos
    </script>

  <% end %>
</div>