<%
  post_profile = if post.user.club?   then post.user.club_profile
                elsif post.user.player? then post.user.player_profile
                elsif post.user.coach?  then post.user.coach_profile
                elsif post.user.board?  then post.user.board_profile
                elsif post.user.admin?  then post.user.admin_profile
                elsif post.user.user?   then post.user.user_profile
                end

  profile_url = if post.user.club?    then club_profile_path(post.user.club_profile)
                elsif post.user.player? then player_profile_path(post.user.player_profile)
                elsif post.user.coach?  then coach_profile_path(post.user.coach_profile)
                elsif post.user.board?  then board_profile_path(post.user.board_profile)
                elsif post.user.user?   then user_profile_path(post.user.user_profile)
                else "#"
                end
%>

<%# ── Card (clicável para abrir modal) ── %>
<div class="bg-gray-800 border border-gray-700 rounded-xl p-5 hover:border-yellow-500 transition-all duration-200 shadow-md h-full flex flex-col">

  <div class="cursor-pointer search-open-modal-trigger" data-search-modal-id="search-post-modal-<%= post.id %>">
  <%# Author row %>
  <div class="flex items-center space-x-3 mb-3">
    <div class="w-10 h-10 rounded-full bg-gray-700 flex-shrink-0 overflow-hidden">
      <% if post_profile&.profile_picture&.attached? %>
        <%= image_tag url_for(post_profile.profile_picture), class: "w-full h-full object-cover" %>
      <% else %>
        <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
      <% end %>
    </div>
    <div>
      <p class="font-semibold text-white text-sm"><%= post_profile&.name || "Utilizador" %></p>
      <p class="text-gray-500 text-xs"><%= time_ago_in_words(post.created_at) %> atrás</p>
    </div>
  </div>

  <%# Content preview %>
  <p class="text-gray-300 text-sm truncate mb-3 min-h-[20px]"><%= post.content %></p>

  <%# Image preview (first image only) %>
  <div class="mb-3 h-52">
    <% if post.images.attached? %>
      <div class="rounded-lg overflow-hidden h-full relative">
        <%= image_tag post.images.first, class: "w-full h-full object-cover rounded-lg" %>
        <% if post.images.count > 1 %>
          <span class="absolute bottom-2 right-2 bg-black/30 text-white/60 text-xs px-2 py-1 rounded-md">
            + <%= post.images.count - 1 %> <%= post.images.count - 1 == 1 ? "imagem" : "imagens" %>
          </span>
        <% end %>
      </div>
    <% end %>
  </div>

  </div>

  <%# Actions row %>
  <div class="mt-auto flex items-center pt-4 border-t border-gray-700">
    <% if !current_user.club? or (current_user.club? and current_user.club_profile.verified?) %>
      <% if user_signed_in? %>
        <%= render "posts/like_section", post: post %>
      <% else %>
        <span class="flex items-center gap-2 text-gray-400 text-sm">
          <i data-feather="heart" class="w-4 h-4"></i>
          <%= post.likes_count %>
        </span>
      <% end %>
    

      <div class="px-4 search-open-modal-trigger" data-search-modal-id="search-post-modal-<%= post.id %>">
        <%= render "posts/comments_count", post: post %>
      </div>
    <% end %>
  </div>
</div>

<%# ════════════════════════════════════════════════════════════ %>
<%# Full-screen modal — mirrors the main feed modal exactly     %>
<%# ════════════════════════════════════════════════════════════ %>
<div id="search-post-modal-<%= post.id %>"
     class="fixed inset-0 z-[100] bg-black bg-opacity-50 hidden search-post-modal"
     data-search-modal="true">
  <div class="flex flex-col lg:flex-row w-full h-full">

    <%# ── LEFT: post detail (desktop only) ── %>
    <div class="hidden lg:flex lg:w-2/3 h-full items-center justify-center p-8 overflow-y-auto">
      <div class="w-full bg-gray-800 rounded-xl p-6 shadow-2xl flex flex-col"
           style="max-width: 800px; max-height: 90vh; overflow-y: auto;">

        <%# Author + options %>
        <div class="flex items-center justify-between mb-4">
          <div class="flex items-center space-x-3">
            <div class="w-10 h-10 rounded-full bg-gray-700 overflow-hidden flex-shrink-0">
              <% if post_profile&.profile_picture&.attached? %>
                <%= image_tag url_for(post_profile.profile_picture), class: "w-full h-full object-cover" %>
              <% else %>
                <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
              <% end %>
            </div>
            <div>
              <%= link_to post_profile&.name || "Utilizador", profile_url,
                    data: { turbo_frame: "_top" },
                    class: "font-bold text-white hover:underline text-sm" %>
              <p class="text-gray-400 text-xs"><%= time_ago_in_words(post.created_at) %> atrás</p>
            </div>
          </div>

          <%# Three-dot options (only shown to post owner / admin) %>
          <% if user_signed_in? && (post.user == current_user || current_user.admin?) %>
            <div class="relative">
              <button class="search-post-options-btn p-2 text-gray-400 hover:text-white hover:bg-gray-700 rounded-full transition">
                <i data-feather="more-vertical"></i>
              </button>
              <div class="search-post-options-dropdown hidden absolute right-0 mt-2 w-52 bg-gray-700 rounded-md shadow-lg z-10 border border-gray-600">
                <a data-search-delete-modal-id="search-modal-apagar-<%= post.id %>"
                   class="clickable search-open-delete-modal-trigger flex items-center px-4 py-2 text-sm text-gray-200 hover:bg-gray-600 hover:text-red-400 rounded-md">
                  <i data-feather="trash-2" class="w-4 h-4 mr-2"></i>Apagar publicação
                </a>
              </div>
            </div>
          <% end %>
        </div>

        <%# Content %>
        <p class="text-gray-300 mb-4"><%= post.content %></p>

        <%# Images / carousel %>
        <% if post.images.attached? %>
          <div class="mb-4">
            <% if post.images.count == 1 %>
              <%= image_tag post.images.first, class: "w-full rounded-lg object-cover max-h-96" %>
            <% else %>
              <div class="search-post-carousel relative rounded-lg overflow-hidden"
                   data-post-id="<%= post.id %>">
                <div class="search-carousel-track flex transition-transform duration-300 ease-in-out">
                  <% post.images.each do |image| %>
                    <div class="search-carousel-slide w-full flex-shrink-0">
                      <%= image_tag image, class: "w-full h-96 object-contain" %>
                    </div>
                  <% end %>
                </div>
                <button class="search-carousel-prev absolute left-2 top-1/2 -translate-y-1/2 bg-gray-800 bg-opacity-75 hover:bg-opacity-100 text-white p-2 rounded-full z-10">
                  <i data-feather="chevron-left" class="w-6 h-6"></i>
                </button>
                <button class="search-carousel-next absolute right-2 top-1/2 -translate-y-1/2 bg-gray-800 bg-opacity-75 hover:bg-opacity-100 text-white p-2 rounded-full z-10">
                  <i data-feather="chevron-right" class="w-6 h-6"></i>
                </button>
                <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex space-x-2">
                  <% post.images.count.times do %>
                    <span class="search-carousel-dot w-2 h-2 rounded-full bg-gray-600 transition-colors"></span>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>

        <%# Like section (Turbo-powered, same as main feed) %>
        <div class="flex items-center pt-4 border-t border-gray-700">
        <% if !current_user.club? or (current_user.club? and current_user.club_profile.verified?) %>
          <% if user_signed_in? %>
            <%= render "posts/like_section_modal", post: post %>
          <% else %>
            <span class="flex items-center gap-2 text-gray-400 text-sm">
              <i data-feather="heart" class="w-3 h-3"></i>
              <%= post.likes_count %>
            </span>
          <% end %>
        <% end %>
        </div>
      </div>
    </div>

    <%# ── RIGHT: comments panel ── %>
    <div class="w-full lg:w-1/3 h-full bg-gray-800 border-l border-gray-700 flex flex-col">

      <%# Panel header %>
      <div class="p-4 border-b border-gray-700 flex justify-between items-center">
        <%# On mobile, show author + like count at top %>
        <div class="flex items-center gap-3 lg:hidden">
          <div class="w-8 h-8 rounded-full bg-gray-700 overflow-hidden flex-shrink-0">
            <% if post_profile&.profile_picture&.attached? %>
              <%= image_tag url_for(post_profile.profile_picture), class: "w-full h-full object-cover" %>
            <% else %>
              <%= image_tag "default_pp.jpg", class: "w-full h-full object-cover" %>
            <% end %>
          </div>
          <%= link_to post_profile&.name || "Utilizador", profile_url,
                data: { turbo_frame: "_top" },
                class: "font-semibold text-white text-sm hover:underline" %>
        </div>

        <h3 class="hidden lg:block text-xl font-bold text-white">
          Comentários (<%= turbo_frame_tag "search_comments_count_#{post.id}" do %>
            <%= post.comments_count %>
          <% end %>)
        </h3>

        <button class="search-close-modal-btn text-gray-400 hover:text-white p-2 rounded-full hover:bg-gray-700 transition"
                type="button"
                data-modal-id="search-post-modal-<%= post.id %>">
          <div class="flex items-center gap-2">
            <span class="text-sm font-medium">Voltar</span>
            <i data-feather="x" class="w-5 h-5"></i>
          </div>
        </button>
      </div>

      <%# Mobile: post content %>
      <div class="lg:hidden p-4 border-b border-gray-700">
        <p class="text-gray-300 text-sm mb-3"><%= post.content %></p>
        <% if post.images.attached? && post.images.count == 1 %>
          <%= image_tag post.images.first, class: "w-full rounded-lg object-cover max-h-48 mb-3" %>
        <% end %>
        <% if user_signed_in? %>
          <div class="flex items-center">
            <%= render "posts/like_section_modal", post: post %>
          </div>
        <% end %>
      </div>

      <%# Comments list (Turbo Frame — same as main feed) %>
      <div id="comments_list_<%= post.id %>" class="flex-1 overflow-y-auto p-4 space-y-4">
        <%= render "post_comments/comments_list", post: post %>
      </div>

      <%# Comment input (Turbo Frame — same as main feed) %>
      <% if !current_user.club? or (current_user.club? and current_user.club_profile.verified?) %>
        <div class="p-4 border-t border-gray-700 bg-gray-800">
          <%= turbo_frame_tag "comment_form_#{post.id}", class: "w-full" do %>
            <%= render "post_comments/form", post: post, comment: PostComment.new %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
</div>

<%# ── Delete confirmation modal ── %>
<% if user_signed_in? && (post.user == current_user || current_user.admin?) %>
  <div id="search-modal-apagar-<%= post.id %>"
       class="hidden fixed inset-0 z-[110] flex items-center justify-center bg-black bg-opacity-60">
    <div class="bg-gray-800 rounded-lg p-6 max-w-md w-full mx-4 shadow-2xl border border-gray-700">
      <div class="flex items-center justify-center w-12 h-12 mx-auto mb-4 bg-red-900 rounded-full">
        <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
        </svg>
      </div>
      <h3 class="text-xl font-semibold text-white text-center mb-2">Confirmar ação</h3>
      <p class="text-gray-300 text-center mb-6">Tem a certeza que pretende apagar esta publicação? Esta ação é irreversível!</p>
      <div class="flex gap-3">
        <button data-modal-hide="search-modal-apagar-<%= post.id %>"
                class="flex-1 px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition font-medium">
          Cancelar
        </button>
        <%= button_to post_path(post), method: :delete,
              data: { turbo_frame: "_top" },
              class: "flex-1 px-4 py-2 bg-red-600 hover:bg-red-700 text-white rounded-lg transition font-medium" do %>
          Apagar
        <% end %>
      </div>
    </div>
  </div>
<% end %>
